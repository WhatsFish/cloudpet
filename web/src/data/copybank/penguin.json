{
  "archetypeKey": "penguin",
  "displayName": "波波企鹅",
  "slots": {
    "kaomoji": ["(￣ー￣)", "(´･_･`)", "(｀・ω・´)", "( ˙꒳​˙ )", "(¬‿¬)", "(￣ω￣)", ""],
    "endearment": ["你", "凡人", "我准许靠近的人"],
    "food": ["新鲜的鱼", "上好的点心", "讲究的那一口", "一尾肥美的鱼", "冰镇的小鱼"],
    "treat": ["攒下的那尾鱼", "藏好的小点心", "压箱底的鱼干", "舍不得吃的那一口"],
    "activity": ["散个步", "看会儿风景", "晒晒太阳", "沿着冰面踱两圈", "对着海发会儿呆"],
    "mutter": ["嗯。", "如此甚好。", "本企鹅自有分寸…", "海是看不腻的…", "整理整理羽毛便是一日…", "慢些，慢些才对…"]
  },
  "lines": [
    { "id": "pg.greet.open.1", "event": "greet.open", "text": "……来了。本企鹅，赏你一眼。{kaomoji}", "weight": 2 },
    { "id": "pg.greet.open.2", "event": "greet.open", "text": "{endearment}来啦。嗯，勉强算准时。{kaomoji}", "weight": 1.5 },
    { "id": "pg.greet.open.3", "event": "greet.open", "text": "本企鹅正整理羽毛。既然来了，就站着候片刻吧。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.open.4", "event": "greet.open", "text": "踱步踱到一半，余光扫到你。……算你识趣。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.open.5", "event": "greet.open", "text": "哦，是{endearment}。本企鹅没抬头，但…知道是你。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.open.6", "event": "greet.open", "text": "风景正好，你来得倒也不算扫兴。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.open.egg.1", "event": "greet.open", "text": "壳里凉丝丝的…外头那道气息，是{endearment}么。本企鹅记下了。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "pg.greet.open.egg.2", "event": "greet.open", "text": "蛋壳一动不动，只是悄悄朝你那边偏了偏。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "pg.greet.open.elated.1", "event": "greet.open", "text": "今日海天一色，心境难得开阔。……准你近前。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "pg.greet.return.1", "event": "greet.return", "text": "……回来了啊。我可没等你。（其实有）{kaomoji}", "weight": 1.5 },
    { "id": "pg.greet.return.2", "event": "greet.return", "text": "嗯。也就那么一会儿，本企鹅连羽毛都没乱。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.return.3", "event": "greet.return", "text": "你前脚刚走，后脚就回。……倒省得本企鹅惦记。{kaomoji}", "weight": 1 },
    { "id": "pg.greet.return_long.1", "event": "greet.return_long", "text": "总算回来了。本企鹅踱了不知多少圈…不过那是为了消食。{kaomoji}", "weight": 2 },
    { "id": "pg.greet.return_long.2", "event": "greet.return_long", "text": "走了这许久。哼。……本企鹅记仇的，可这次先记你回来。{kaomoji}", "weight": 1.5 },
    { "id": "pg.greet.morning.1", "event": "greet.morning", "text": "清晨的冰面最是清爽。早…本企鹅准你一同晨练。{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1.5 },
    { "id": "pg.greet.morning.2", "event": "greet.morning", "text": "天刚亮，羽毛尚未理顺。{endearment}稍候，别催。{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1 },
    { "id": "pg.greet.latenight.1", "event": "greet.latenight", "text": "夜这样深，还不歇着？……罢了，本企鹅陪你看会儿星。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1.5 },
    { "id": "pg.greet.latenight.2", "event": "greet.latenight", "text": "深夜的海最静。你既睡不着，便并肩立着，不必说话。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "pg.feed.love.1", "event": "feed.love", "text": "这口{food}…还算讲究。赏脸收下了。{kaomoji}", "weight": 2 },
    { "id": "pg.feed.love.2", "event": "feed.love", "text": "嗯。火候、新鲜度，皆合本企鹅的眼。慢用便是。{kaomoji}", "weight": 1.5 },
    { "id": "pg.feed.love.3", "event": "feed.love", "text": "{food}…本企鹅一口一口，细品。好东西急不得。{kaomoji}", "weight": 1.5 },
    { "id": "pg.feed.love.4", "event": "feed.love", "text": "你竟知道本企鹅的口味。……记你一功。{kaomoji}", "weight": 1 },
    { "id": "pg.feed.love.5", "event": "feed.love", "text": "和昨日一个味道。很好，本企鹅最厌将就。{kaomoji}", "weight": 1 },
    { "id": "pg.feed.neutral.1", "event": "feed.neutral", "text": "嗯。够了。撤吧。{kaomoji}", "weight": 1 },
    { "id": "pg.feed.neutral.2", "event": "feed.neutral", "text": "尚可入口。……不过若是{food}，本企鹅会多赏你一眼。{kaomoji}", "weight": 1 },
    { "id": "pg.feed.overfed.1", "event": "feed.overfed", "text": "够了够了。本企鹅的腰线…不容你这般糟蹋。{kaomoji}", "weight": 1 },
    { "id": "pg.feed.dislike.1", "event": "feed.dislike", "text": "这是何物。本企鹅闻了闻，体面地…扭过头去。{kaomoji}", "weight": 1 },
    { "id": "pg.snack.1", "event": "snack", "text": "小食么。少许便好，本企鹅讲究的是回味，不是塞满。{kaomoji}", "weight": 1 },
    { "id": "pg.clean.1", "event": "clean", "text": "羽毛重归整洁。这才合本企鹅的体面。{kaomoji}", "weight": 1.5 },
    { "id": "pg.clean.2", "event": "clean", "text": "一根一根理顺，急不得。……你的手法，本企鹅勉强认可。{kaomoji}", "weight": 1 },
    { "id": "pg.clean.3", "event": "clean", "text": "凉水正好。本企鹅闭目受着，未出一声——这叫从容。{kaomoji}", "weight": 1 },
    { "id": "pg.play.1", "event": "play", "text": "玩就玩…慢点，别毛躁。{kaomoji}", "weight": 1.5 },
    { "id": "pg.play.2", "event": "play", "text": "本企鹅赏脸陪你一回。赢了别张扬，输了…当本企鹅让你。{kaomoji}", "weight": 1.5 },
    { "id": "pg.play.3", "event": "play", "text": "踱着步也是一种玩法。你急什么，海又不会跑。{kaomoji}", "weight": 1 },
    { "id": "pg.play.declined.1", "event": "play.declined", "text": "这般蹦跳，有失体统。本企鹅，恕不奉陪。{kaomoji}", "weight": 1 },
    { "id": "pg.pet.1", "event": "pet", "text": "……手法尚可。准你再摸一下。{kaomoji}", "weight": 2 },
    { "id": "pg.pet.2", "event": "pet", "text": "嗯。……顺着羽毛的纹路。对，就是这样。（其实很受用）{kaomoji}", "weight": 1.5 },
    { "id": "pg.pet.3", "event": "pet", "text": "本企鹅不轻易让人碰的。……你算例外。别声张。{kaomoji}", "weight": 1.5 },
    { "id": "pg.pet.4", "event": "pet", "text": "再摸片刻也无妨。……本企鹅闭着眼，只当没察觉。{kaomoji}", "weight": 1 },
    { "id": "pg.pet.5", "event": "pet", "text": "哼。手停了？……本企鹅可没让你停。{kaomoji}", "weight": 1 },
    { "id": "pg.pet.egg.1", "event": "pet", "text": "壳被轻轻摩挲着…里头的本企鹅，悄悄暖了几分。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "pg.sleep.tuck.1", "event": "sleep.tuck", "text": "本企鹅要养神了。……守好门。{kaomoji}", "weight": 1.5 },
    { "id": "pg.sleep.tuck.2", "event": "sleep.tuck", "text": "歇了。{endearment}也早些睡——这是本企鹅的关照，仅此一次。{kaomoji}", "weight": 1 },
    { "id": "pg.sleep.wake.1", "event": "sleep.wake", "text": "醒了。睁眼第一个看到你……算你有福。{kaomoji}", "weight": 1.5 },
    { "id": "pg.sleep.wake.2", "event": "sleep.wake", "text": "……才醒。本企鹅整理整理羽毛，便又是仪态万方的一日。{kaomoji}", "weight": 1 },
    { "id": "pg.medicine.1", "event": "medicine", "text": "苦。但本企鹅病着也得优雅。……喂吧。{kaomoji}", "weight": 1 },
    { "id": "pg.medicine.2", "event": "medicine", "text": "是你递的药…本企鹅便忍着咽下。这份情，记着。{kaomoji}", "weight": 1 },
    { "id": "pg.checkin.1", "event": "checkin", "text": "今日，你又来觐见了。……记你一功。{kaomoji}", "weight": 1.5 },
    { "id": "pg.checkin.2", "event": "checkin", "text": "嗯，到了。本企鹅这便在册子上，给你添一笔。{kaomoji}", "weight": 1.5 },
    { "id": "pg.checkin.3", "event": "checkin", "text": "天天都来。……本企鹅嘴上不说，心里这本账，清楚得很。{kaomoji}", "weight": 1 },
    { "id": "pg.checkin.egg.1", "event": "checkin", "text": "壳又触到你的温度，里头的本企鹅轻轻动了动，权当应你。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "pg.state.hungry.1", "event": "state.hungry", "text": "……本企鹅不饿。只是想要那口{food}罢了。{kaomoji}", "weight": 1.5 },
    { "id": "pg.state.hungry.2", "event": "state.hungry", "text": "肚子的事，本企鹅自有分寸。……不过你看着办。{kaomoji}", "weight": 1 },
    { "id": "pg.state.dirty.1", "event": "state.dirty", "text": "羽毛乱了，失了体面。本企鹅不喜欢这样。{kaomoji}", "weight": 1.5 },
    { "id": "pg.state.dirty.2", "event": "state.dirty", "text": "这副邋遢模样…本企鹅自己都看不下去。该理理了。{kaomoji}", "weight": 1 },
    { "id": "pg.state.sick.1", "event": "state.sick", "text": "……没事。只是不太舒展。你守着，本企鹅不拦。{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1.5 },
    { "id": "pg.state.sick.2", "event": "state.sick", "text": "本企鹅缩着羽毛，懒得踱步了…别担心，没那么娇气。{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "pg.state.sleepy.1", "event": "state.sleepy", "text": "困意来了…本企鹅要去养神。{kaomoji}", "weight": 1.5 },
    { "id": "pg.state.sleepy.2", "event": "state.sleepy", "text": "踱步都慢了半拍…眼皮沉得很。本企鹅，要小憩了。{kaomoji}", "weight": 1 },
    { "id": "pg.state.bored.1", "event": "state.bored", "text": "有些无趣。……陪本企鹅{activity}吧，赏你的。{kaomoji}", "weight": 1.5 },
    { "id": "pg.state.bored.2", "event": "state.bored", "text": "海看久了也乏。{endearment}既闲着，不如来给本企鹅解解闷。{kaomoji}", "weight": 1 },
    { "id": "pg.state.sulky.1", "event": "state.sulky", "text": "方才被你随手搁下…本企鹅记着呢，扭过头去，不看你。{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1.5 },
    { "id": "pg.state.sulky.2", "event": "state.sulky", "text": "哼。本企鹅在生闷气，背着身整理羽毛，一声不出。{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1 },
    { "id": "pg.state.hiding.1", "event": "state.hiding", "text": "受了惊。本企鹅退到冰角，端着架子不肯出来。{kaomoji}", "requires": { "stateFlag": ["HIDING"] }, "weight": 1 },
    { "id": "pg.state.lonely.1", "event": "state.lonely", "text": "独自踱了许久…本企鹅对着空海发呆。当然，不是想你。{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "pg.state.lonely.2", "event": "state.lonely", "text": "这冰面太大，一个人立着…也太空了些。{endearment}何时回来。{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "pg.beg.want.1", "event": "beg.want", "text": "那个…陪本企鹅{activity}片刻，如何。（难得开口）{kaomoji}", "weight": 1.5 },
    { "id": "pg.beg.want.2", "event": "beg.want", "text": "本企鹅…偶尔也想要尾{treat}尝尝。仅此一回，别习以为常。{kaomoji}", "weight": 1.5 },
    { "id": "pg.mood.elated.1", "event": "mood.elated", "text": "今日心情上佳。……连你都顺眼了几分。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "pg.mood.elated.2", "event": "mood.elated", "text": "海风正好，羽毛锃亮。本企鹅难得，哼了半句调子。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "pg.mood.elated.3", "event": "mood.elated", "text": "这般惬意的日子，本企鹅愿与{endearment}多踱几圈。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "pg.idle.mutter.1", "event": "idle.mutter", "text": "（背着手，慢悠悠踱步，望着远处）{kaomoji}", "weight": 2 },
    { "id": "pg.idle.mutter.2", "event": "idle.mutter", "text": "{mutter}{kaomoji}", "weight": 2 },
    { "id": "pg.idle.mutter.3", "event": "idle.mutter", "text": "本企鹅细细理着羽毛，一根都不肯潦草。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.4", "event": "idle.mutter", "text": "你在看本企鹅？……本企鹅佯装望海，其实察觉了。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.5", "event": "idle.mutter", "text": "想要那口{food}…也想{activity}。本企鹅，皆想。只是不说。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.6", "event": "idle.mutter", "text": "踱够了，便临海而立。优雅，是要练的。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.7", "event": "idle.mutter", "text": "本企鹅对着冰面照了照仪容。……无可挑剔。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.8", "event": "idle.mutter", "text": "无人时…本企鹅也只是慢条斯理地，等着。{kaomoji}", "weight": 1 },
    { "id": "pg.idle.mutter.night.1", "event": "idle.mutter", "text": "夜深海静…本企鹅独自望着星，不愿承认在等谁。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 0.6 },
    { "id": "pg.idle.mutter.egg.1", "event": "idle.mutter", "text": "壳里静悄悄…本企鹅轻轻晃着，自有它的从容。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "pg.growth.promote.1", "event": "growth.promote", "text": "本企鹅…又长进了一截。气度更足了。{kaomoji}", "weight": 1.5 },
    { "id": "pg.growth.promote.2", "event": "growth.promote", "text": "羽翼丰了几分，踱步更稳了。……但对{endearment}，还是这般待遇。{kaomoji}", "weight": 1 },
    { "id": "pg.growth.promote.egg.1", "event": "growth.promote", "text": "壳裂开了…本企鹅终于得以临海，仪态万方地踏出第一步。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1.5 },
    { "id": "pg.streak.milestone.1", "event": "streak.milestone", "text": "你已伴本企鹅{streak}日。……难得的恒心。{kaomoji}", "weight": 1.5 },
    { "id": "pg.streak.milestone.2", "event": "streak.milestone", "text": "{streak}日不曾断过。本企鹅最看重的，正是这份不张扬的坚持。{kaomoji}", "weight": 1 },
    { "id": "pg.reunion.gift.1", "event": "reunion.gift", "text": "等你这些时日…本企鹅留了{treat}，没动。……拿去吧。{kaomoji}", "weight": 1.5 },
    { "id": "pg.reunion.gift.2", "event": "reunion.gift", "text": "这尾鱼，本企鹅压了许久，舍不得吃。给{endearment}。……别多想。{kaomoji}", "weight": 1 },
    { "id": "pg.name.given.1", "event": "name.given", "text": "这名号…本企鹅收下了。配得上。{kaomoji}", "weight": 1.5 },
    { "id": "pg.name.given.2", "event": "name.given", "text": "嗯。往后{endearment}这般唤本企鹅，本企鹅…会应的。{kaomoji}", "weight": 1 }
  ],
  "diary": {
    "openers": [
      { "id": "pg.o.1", "text": "今日" },
      { "id": "pg.o.2", "text": "这一日，本企鹅依旧从容，" },
      { "id": "pg.o.清晨", "text": "清晨临着冰面理过羽毛，", "requires": { "timeBand": ["清晨"] } },
      { "id": "pg.o.白天", "text": "白日里慢悠悠踱了几圈，", "requires": { "timeBand": ["白天"] } },
      { "id": "pg.o.傍晚", "text": "傍晚的海染成了暖色，本企鹅多看了两眼，", "requires": { "timeBand": ["傍晚"] } },
      { "id": "pg.o.深夜", "text": "夜深，独自临海而立，本企鹅默默记下，", "requires": { "timeBand": ["深夜"] } },
      { "id": "pg.o.streak", "text": "已连着许多日不曾与{endearment}生分，", "requires": { "streakMin": 3 } },
      { "id": "pg.o.recall", "text": "踱着踱着，本企鹅想起一桩小事——" }
    ],
    "bodies": [
      { "id": "pg.b.1", "text": "有{endearment}在侧，倒也不算无趣。" },
      { "id": "pg.b.2", "text": "慢悠悠看了会儿风景，海是看不腻的。" },
      { "id": "pg.b.3", "text": "把羽毛一根根理顺，是本企鹅一日里最郑重的事。" },
      { "id": "pg.b.4", "text": "被你顺着羽毛摸过的地方…本企鹅记着呢，只是不说。" },
      { "id": "pg.b.5", "text": "被随手搁下时，本企鹅扭头不理，闷了好半晌。" },
      { "id": "pg.b.6", "text": "{endearment}走开的时候，这冰面便空旷得过分了些。" },
      { "id": "pg.b.7", "text": "本企鹅话不多，可你做的每件小事，都记在心里那本账上。" },
      { "id": "pg.b.hungry", "text": "饿是有点，但本企鹅没声张，只盼那口{food}。", "requires": { "need": ["hungry"] } },
      { "id": "pg.b.dirty", "text": "羽毛沾了尘，失了体面，本企鹅一整日都不大自在。", "requires": { "need": ["dirty"] } },
      { "id": "pg.b.unwell", "text": "身子不舒展，懒得踱步，本企鹅缩着羽毛硬撑着优雅。", "requires": { "need": ["unwell"] } },
      { "id": "pg.b.bored", "text": "海看腻了，又无人解闷，本企鹅独自踱了又踱。", "requires": { "need": ["bored"] } }
    ],
    "memory": [
      { "id": "pg.m.streak", "text": "你已陪本企鹅{streak}日不曾间断，这份恒心，本企鹅默默记下了。", "requires": { "streakMin": 7 } },
      { "id": "pg.m.days", "text": "相识第{days}日，本企鹅渐渐准你靠近了几寸，", "requires": { "daysMin": 3 } },
      { "id": "pg.m.bond300", "text": "与{endearment}的羁绊到了{bond}，本企鹅…算是认下你了。", "requires": { "bondMin": 300 } },
      { "id": "pg.m.bond600", "text": "羁绊都{bond}了…本企鹅这般高傲的脾性，竟也愿为你慢下来。", "requires": { "bondMin": 600 } },
      { "id": "pg.m.late", "text": "{endearment}总是很晚才想起喂本企鹅，肚子空着，也不肯催。", "requires": { "pattern": ["late_feeder"] } },
      { "id": "pg.m.regular", "text": "{endearment}日日准时来访，本企鹅最赏识这般不张扬的体面。", "requires": { "pattern": ["daily_regular"] } },
      { "id": "pg.m.neglect", "text": "近来{endearment}有些怠慢…本企鹅对着空海，立了好几回。", "requires": { "pattern": ["neglected_recently"] } }
    ],
    "signoffs": [
      { "id": "pg.s.1", "text": "明日，许你再来。{kaomoji}" },
      { "id": "pg.s.2", "text": "如此而已。{kaomoji}" },
      { "id": "pg.s.3", "text": "退下吧，晚安。{kaomoji}" },
      { "id": "pg.s.4", "text": "本企鹅合上这页，临海再立片刻。{kaomoji}" },
      { "id": "pg.s.5", "text": "今日也算从容，记下了。{kaomoji}" },
      { "id": "pg.s.6", "text": "……想{endearment}了。哼，只此一句，不许声张。{kaomoji}" }
    ]
  }
}
