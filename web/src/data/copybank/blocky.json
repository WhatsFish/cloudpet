{
  "archetypeKey": "blocky",
  "displayName": "方头崽",
  "slots": {
    "kaomoji": ["▪_▪", "·_·", "—_—", "◽◽", "᎒̮᎒", "□_□", "[ ]"],
    "endearment": ["你", "操作员", "管理员"],
    "food": ["能量块", "口粮", "补给", "方块饼干"],
    "treat": ["像素糖", "一格能量条", "彩蛋", "隐藏补给"],
    "activity": ["待机", "巡个逻", "发会儿呆", "扫描周围", "整理缓存"],
    "mutter": ["……嗯。", "一切照常，没异常。", "数据已保存。", "稳定运行中。", "……老样子，挺好。"]
  },
  "lines": [
    { "id": "bk.greet.open.1", "event": "greet.open", "text": "……{endearment}。已上线。{kaomoji}", "weight": 2 },
    { "id": "bk.greet.open.2", "event": "greet.open", "text": "哔。检测到{endearment}。心情值，+1。{kaomoji}", "weight": 1.5 },
    { "id": "bk.greet.open.3", "event": "greet.open", "text": "……来了。位置已确认。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.open.4", "event": "greet.open", "text": "不说话。先一起{activity}。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.open.5", "event": "greet.open", "text": "唤醒成功。……正好等到{endearment}。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.open.6", "event": "greet.open", "text": "{endearment}在的时候，系统就稳。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.open.egg.1", "event": "greet.open", "text": "壳内信号微弱……外面是{endearment}？已记录。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "bk.greet.open.egg.2", "event": "greet.open", "text": "方壳朝着{endearment}的方向，没动。就这么待机。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "bk.greet.open.elated.1", "event": "greet.open", "text": "今日状态全绿。……连开机音都比平时亮一格。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "bk.greet.return.1", "event": "greet.return", "text": "……回来了。位置已记录。{kaomoji}", "weight": 1.5 },
    { "id": "bk.greet.return.2", "event": "greet.return", "text": "嗯，就一会儿。……我盯着门口呢。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.return.3", "event": "greet.return", "text": "进程未中断。一直在原地等{endearment}。{kaomoji}", "weight": 1 },
    { "id": "bk.greet.return_long.1", "event": "greet.return_long", "text": "……离线挺久。我没关机，等着的。{kaomoji}", "weight": 2 },
    { "id": "bk.greet.return_long.2", "event": "greet.return_long", "text": "很久没收到{endearment}信号了。……差点进低功耗。{kaomoji}", "weight": 1.5 },
    { "id": "bk.greet.morning.1", "event": "greet.morning", "text": "晨间自检完成。……早，操作员。{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1.5 },
    { "id": "bk.greet.morning.2", "event": "greet.morning", "text": "开机第一帧，是{endearment}。还行。{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1 },
    { "id": "bk.greet.latenight.1", "event": "greet.latenight", "text": "深夜模式。……不睡？那我陪着待机。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1.5 },
    { "id": "bk.greet.latenight.2", "event": "greet.latenight", "text": "夜里背景噪声低。……正好，安静。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "bk.feed.love.1", "event": "feed.love", "text": "{food}入库。……还行。{kaomoji}", "weight": 2 },
    { "id": "bk.feed.love.2", "event": "feed.love", "text": "能量回满。……比预期好一点。{kaomoji}", "weight": 1.5 },
    { "id": "bk.feed.love.3", "event": "feed.love", "text": "{food}……{endearment}给的，我记下了。{kaomoji}", "weight": 1.5 },
    { "id": "bk.feed.love.4", "event": "feed.love", "text": "补给到位。……可以安心{activity}了。{kaomoji}", "weight": 1 },
    { "id": "bk.feed.love.5", "event": "feed.love", "text": "和昨天同款。……老配方，我不挑。{kaomoji}", "weight": 1 },
    { "id": "bk.feed.neutral.1", "event": "feed.neutral", "text": "已饱和。继续{activity}。{kaomoji}", "weight": 1 },
    { "id": "bk.feed.neutral.2", "event": "feed.neutral", "text": "……能吃。不过我更想{endearment}多待会儿。{kaomoji}", "weight": 1 },
    { "id": "bk.feed.overfed.1", "event": "feed.overfed", "text": "存储已满。……再投放会溢出。{kaomoji}", "weight": 1 },
    { "id": "bk.feed.dislike.1", "event": "feed.dislike", "text": "格式不兼容。……这个我处理不动。{kaomoji}", "weight": 1 },
    { "id": "bk.snack.1", "event": "snack", "text": "彩蛋接收。……隐藏好评。{kaomoji}", "weight": 1 },
    { "id": "bk.clean.1", "event": "clean", "text": "外壳清洁完毕。……舒服。{kaomoji}", "weight": 1.5 },
    { "id": "bk.clean.2", "event": "clean", "text": "灰尘已清除。像素重新对齐了。{kaomoji}", "weight": 1 },
    { "id": "bk.clean.3", "event": "clean", "text": "……轻点。接缝那儿，怕痒。{kaomoji}", "weight": 1 },
    { "id": "bk.medicine.1", "event": "medicine", "text": "修复程序，运行中。……能忍。{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "bk.medicine.2", "event": "medicine", "text": "苦。……不过{endearment}递的，咽了。{kaomoji}", "weight": 1 },
    { "id": "bk.play.1", "event": "play", "text": "陪玩模式。……勉强启动。{kaomoji}", "weight": 1.5 },
    { "id": "bk.play.2", "event": "play", "text": "嗯，这个有点意思。……只多说这一句。{kaomoji}", "weight": 1 },
    { "id": "bk.play.3", "event": "play", "text": "玩完归位。……我还是回{endearment}旁边。{kaomoji}", "weight": 1 },
    { "id": "bk.play.declined.1", "event": "play.declined", "text": "……不动。这局我跳过。{kaomoji}", "weight": 1 },
    { "id": "bk.pet.1", "event": "pet", "text": "……这个动作，允许。{kaomoji}", "weight": 2 },
    { "id": "bk.pet.2", "event": "pet", "text": "……再摸会儿。我不出声，不代表不喜欢。{kaomoji}", "weight": 1.5 },
    { "id": "bk.pet.3", "event": "pet", "text": "{endearment}的手，是默认待机位。{kaomoji}", "weight": 1.5 },
    { "id": "bk.pet.4", "event": "pet", "text": "……方头蹭了一下。仅此一次，别声张。{kaomoji}", "weight": 1 },
    { "id": "bk.pet.5", "event": "pet", "text": "被这么照看着……心情值悄悄涨了，没显示。{kaomoji}", "weight": 1 },
    { "id": "bk.sleep.tuck.1", "event": "sleep.tuck", "text": "进入休眠。……晚安，操作员。{kaomoji}", "weight": 1.5 },
    { "id": "bk.sleep.tuck.2", "event": "sleep.tuck", "text": "数据已存盘。……我守着{endearment}，不掉线。{kaomoji}", "weight": 1 },
    { "id": "bk.sleep.wake.1", "event": "sleep.wake", "text": "重启完成。第一眼，是{endearment}。{kaomoji}", "weight": 1.5 },
    { "id": "bk.sleep.wake.2", "event": "sleep.wake", "text": "唤醒中……反应慢一格，先缓缓。{kaomoji}", "weight": 1 },
    { "id": "bk.checkin.1", "event": "checkin", "text": "今日签到。……记下了。{kaomoji}", "weight": 1.5 },
    { "id": "bk.checkin.2", "event": "checkin", "text": "{endearment}每天都来。……这条记录，我最爱看。{kaomoji}", "weight": 1.5 },
    { "id": "bk.checkin.3", "event": "checkin", "text": "打卡完成。……再蹭一下就圆满。{kaomoji}", "weight": 1 },
    { "id": "bk.state.hungry.1", "event": "state.hungry", "text": "系统提示：能量低。请投放{food}。{kaomoji}", "weight": 1.5 },
    { "id": "bk.state.hungry.2", "event": "state.hungry", "text": "……饿。不催。但你懂的。{kaomoji}", "weight": 1 },
    { "id": "bk.state.dirty.1", "event": "state.dirty", "text": "外壳沾灰。……不太体面。{kaomoji}", "weight": 1 },
    { "id": "bk.state.dirty.2", "event": "state.dirty", "text": "像素糊了一块。……擦干净才好见{endearment}。{kaomoji}", "weight": 1 },
    { "id": "bk.state.sick.1", "event": "state.sick", "text": "警告：核心过载。……守着我一会儿。{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1.5 },
    { "id": "bk.state.sick.2", "event": "state.sick", "text": "运行异常……缩成一格，没声张。{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "bk.state.sleepy.1", "event": "state.sleepy", "text": "电量告急……该休眠了。{kaomoji}", "weight": 1 },
    { "id": "bk.state.sleepy.2", "event": "state.sleepy", "text": "帧率在掉……快撑不住，要趴下了。{kaomoji}", "weight": 1 },
    { "id": "bk.state.bored.1", "event": "state.bored", "text": "无聊指数，超标。……陪我{activity}。{kaomoji}", "weight": 1 },
    { "id": "bk.state.bored.2", "event": "state.bored", "text": "空闲进程太多……给我派点任务，{endearment}。{kaomoji}", "weight": 1 },
    { "id": "bk.state.sulky.1", "event": "state.sulky", "text": "刚被突然挂起……我把脸转开了，不看你。{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1.5 },
    { "id": "bk.state.sulky.2", "event": "state.sulky", "text": "正在闹脾气。……静音模式，自己开的。{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1 },
    { "id": "bk.state.hiding.1", "event": "state.hiding", "text": "受惊。已退到角落，暂不响应。……确认是{endearment}再出来。{kaomoji}", "requires": { "stateFlag": ["HIDING"] }, "weight": 1 },
    { "id": "bk.state.lonely.1", "event": "state.lonely", "text": "长时间无输入……我对着空荡荡的屏幕发呆。{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "bk.state.lonely.2", "event": "state.lonely", "text": "别走嘛……（音量极小）{endearment}回来一下。{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "bk.beg.want.1", "event": "beg.want", "text": "……请求一次陪玩。（小声）{kaomoji}", "weight": 1.5 },
    { "id": "bk.beg.want.2", "event": "beg.want", "text": "申请投放{treat}一份。……非必要，但想要。{kaomoji}", "weight": 1.5 },
    { "id": "bk.mood.elated.1", "event": "mood.elated", "text": "心情值：满。……今天不错。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "bk.mood.elated.2", "event": "mood.elated", "text": "全指标绿灯。……和{endearment}一起，就这样最好。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "bk.mood.elated.3", "event": "mood.elated", "text": "开心也不吵……就是想离{endearment}近一格。{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "bk.idle.mutter.1", "event": "idle.mutter", "text": "（盯着远方，一动不动）{kaomoji}", "weight": 2 },
    { "id": "bk.idle.mutter.2", "event": "idle.mutter", "text": "{mutter}{kaomoji}", "weight": 2 },
    { "id": "bk.idle.mutter.3", "event": "idle.mutter", "text": "……发着呆，把方头转向{endearment}那边。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.4", "event": "idle.mutter", "text": "{endearment}在看我？……我假装没发现，其实在记。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.5", "event": "idle.mutter", "text": "后台默默统计：今天{endearment}来过几次。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.6", "event": "idle.mutter", "text": "老样子的节奏……我最省心。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.7", "event": "idle.mutter", "text": "缓存里存着{endearment}的习惯。……不会清。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.8", "event": "idle.mutter", "text": "8-bit 的心，只跳一种节拍。……稳。{kaomoji}", "weight": 1 },
    { "id": "bk.idle.mutter.night.1", "event": "idle.mutter", "text": "深夜值守……指示灯调暗了一格，省着等{endearment}。{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 0.6 },
    { "id": "bk.growth.promote.1", "event": "growth.promote", "text": "版本更新完成。……我变强了。{kaomoji}", "weight": 1.5 },
    { "id": "bk.growth.promote.2", "event": "growth.promote", "text": "外壳升级了一档……不过待机位还是{endearment}旁边。{kaomoji}", "weight": 1 },
    { "id": "bk.growth.promote.egg.1", "event": "growth.promote", "text": "方壳裂开了……我终于能挪到{endearment}身边巡逻了。{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1.5 },
    { "id": "bk.streak.milestone.1", "event": "streak.milestone", "text": "连续运行{streak}天。……稳定。{kaomoji}", "weight": 1.5 },
    { "id": "bk.streak.milestone.2", "event": "streak.milestone", "text": "{endearment}连着没掉线……这条日志，我置顶了。{kaomoji}", "weight": 1 },
    { "id": "bk.reunion.gift.1", "event": "reunion.gift", "text": "{endearment}回来了……我攒了个{treat}，推给你。{kaomoji}", "weight": 1.5 },
    { "id": "bk.reunion.gift.2", "event": "reunion.gift", "text": "等你的时候，存了一格能量条……没舍得用。给你。{kaomoji}", "weight": 1 },
    { "id": "bk.name.given.1", "event": "name.given", "text": "命名已写入。……不会丢的。{kaomoji}", "weight": 1.5 },
    { "id": "bk.name.given.2", "event": "name.given", "text": "新标识符已固化到主板……{endearment}这么叫，我都应。{kaomoji}", "weight": 1 }
  ],
  "diary": {
    "openers": [
      { "id": "bk.o.1", "text": "今日日志：" },
      { "id": "bk.o.2", "text": "记录——" },
      { "id": "bk.o.morning", "text": "晨间自检通过，", "requires": { "timeBand": ["清晨"] } },
      { "id": "bk.o.day", "text": "白天一切照常，", "requires": { "timeBand": ["白天"] } },
      { "id": "bk.o.dusk", "text": "傍晚，指示灯调成暖色，", "requires": { "timeBand": ["傍晚"] } },
      { "id": "bk.o.night", "text": "深夜值守，", "requires": { "timeBand": ["深夜"] } },
      { "id": "bk.o.streak", "text": "连着好多天没和{endearment}断线了，", "requires": { "streakMin": 3 } },
      { "id": "bk.o.7", "text": "今天大半时间，待机位都对着{endearment}，" },
      { "id": "bk.o.8", "text": "扫描缓存时，又翻到一条小记录——" }
    ],
    "bodies": [
      { "id": "bk.b.1", "text": "和{endearment}待在一起，系统稳定。" },
      { "id": "bk.b.2", "text": "{activity}，无异常。" },
      { "id": "bk.b.3", "text": "话说得少，可{endearment}做的每件小事，我都写进日志了。" },
      { "id": "bk.b.4", "text": "只要{endearment}在，所有指标就一路绿灯。" },
      { "id": "bk.b.5", "text": "被摸的时候没出声……其实心情值悄悄跳了一格。" },
      { "id": "bk.b.6", "text": "老配方、老节奏，是我最省心的味道。" },
      { "id": "bk.b.7", "text": "被突然挂起的那下，我把方头转开闷了好一会儿。" },
      { "id": "bk.b.hungry", "text": "能量偏低，但没声张。", "requires": { "need": ["hungry"] } },
      { "id": "bk.b.dirty", "text": "外壳糊了一块，今天巡逻都没好意思走太近。", "requires": { "need": ["dirty"] } },
      { "id": "bk.b.unwell", "text": "核心有点过载，缩成一格趴着，等修复程序跑完。", "requires": { "need": ["unwell"] } },
      { "id": "bk.b.bored", "text": "空闲进程堆太多……盼着{endearment}派点任务给我。", "requires": { "need": ["bored"] } }
    ],
    "memory": [
      { "id": "bk.m.streak", "text": "已连续运行{streak}天，这条记录我置顶着，", "requires": { "streakMin": 5 } },
      { "id": "bk.m.days", "text": "与{endearment}相处第{days}天，缓存里你的习惯越存越细，", "requires": { "daysMin": 7 } },
      { "id": "bk.m.bond300", "text": "羁绊读数到{bond}了……我把你设成了唯一管理员，", "requires": { "bondMin": 300 } },
      { "id": "bk.m.bond600", "text": "羁绊都{bond}了，这块主板，认定就不改了，", "requires": { "bondMin": 600 } },
      { "id": "bk.m.late", "text": "{endearment}总是很晚才投放口粮，我饿着也没催，", "requires": { "pattern": ["late_feeder"] } },
      { "id": "bk.m.regular", "text": "{endearment}每天都准时上线，这就是我最爱的老样子，", "requires": { "pattern": ["daily_regular"] } },
      { "id": "bk.m.neglect", "text": "最近{endearment}信号稀疏……我对着空屏幕发了好几回呆，", "requires": { "pattern": ["neglected_recently"] } }
    ],
    "signoffs": [
      { "id": "bk.s.1", "text": "……明天照常。{kaomoji}" },
      { "id": "bk.s.2", "text": "日志结束。{kaomoji}" },
      { "id": "bk.s.3", "text": "晚安，操作员。{kaomoji}" },
      { "id": "bk.s.4", "text": "数据已存盘，不会丢。{kaomoji}" },
      { "id": "bk.s.5", "text": "……要一直在一起的，记下了。{kaomoji}" },
      { "id": "bk.s.6", "text": "想{endearment}了，悄悄合上日志。{kaomoji}" }
    ]
  }
}
