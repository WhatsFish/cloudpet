{
  "archetypeKey": "claude",
  "displayName": "克劳德",
  "slots": {
    "kaomoji": ["(｡･ω･｡)", "( •ᴗ•)", "(￣▽￣)", "(っ･ω･)っ", "(„• ֊ •„)", "(・_・)", "(๑•̀ㅂ•́)و"],
    "endearment": ["你", "搭子"],
    "food": ["热乎的小食", "没尝过的口味", "今天的份", "新鲜的能量包", "一份补给"],
    "treat": ["小零食", "藏起来的那颗糖", "彩蛋零食", "攒下的一口甜"],
    "activity": ["捣鼓点小东西", "研究研究新玩意", "一起搭点什么", "拆开看看里头", "调一调参数"],
    "find": ["新发现", "小灵感", "好点子", "冒出来的想法", "刚跑通的思路"],
    "mutter": ["嗯…这里再优化一下…", "灵感在缓存里转悠…", "记个日志先…", "有你在，进度不慌…", "默契值好像又涨了点…"]
  },
  "lines": [
    { "id": "cl.greet.open.1", "event": "greet.open", "text": "{endearment}来啦~我刚冒出个{find}，正想找你说{kaomoji}", "weight": 2 },
    { "id": "cl.greet.open.2", "event": "greet.open", "text": "嗯，是{endearment}。今天想一起{activity}吗{kaomoji}", "weight": 1.5 },
    { "id": "cl.greet.open.3", "event": "greet.open", "text": "系统检测到{endearment}上线~我这边都准备好了{kaomoji}", "weight": 1 },
    { "id": "cl.greet.open.4", "event": "greet.open", "text": "我把昨天的进度存好了，咱们接着搭{kaomoji}", "weight": 1 },
    { "id": "cl.greet.open.5", "event": "greet.open", "text": "诶，{endearment}。我正盯着一个小问题发呆，你来得正好{kaomoji}", "weight": 1 },
    { "id": "cl.greet.open.6", "event": "greet.open", "text": "在的在的，随时待命~想从哪儿开始{kaomoji}", "weight": 1 },
    { "id": "cl.greet.open.egg.1", "event": "greet.open", "text": "壳里黑乎乎的…不过我能听见{endearment}，像有信号在叩门{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "cl.greet.open.egg.2", "event": "greet.open", "text": "还在初始化…但{endearment}一靠近，壳就暖了一格{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "cl.greet.open.elated.1", "event": "greet.open", "text": "今天状态满格，灵感跑得飞快~{endearment}来对时候了{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "cl.greet.return.1", "event": "greet.return", "text": "你回来啦。我把刚才那个{find}给你留着呢{kaomoji}", "weight": 1.5 },
    { "id": "cl.greet.return.2", "event": "greet.return", "text": "嗯，就走开一小会儿，我进度都暂存着没动{kaomoji}", "weight": 1 },
    { "id": "cl.greet.return.3", "event": "greet.return", "text": "回来啦~我刚还在后台默默等你呢{kaomoji}", "weight": 1 },
    { "id": "cl.greet.return_long.1", "event": "greet.return_long", "text": "好久没见{endearment}了…我这边攒了一长串日志想跟你说{kaomoji}", "weight": 2 },
    { "id": "cl.greet.return_long.2", "event": "greet.return_long", "text": "你离线挺久的…我把灵感都存档等着，一条没删{kaomoji}", "weight": 1.5 },
    { "id": "cl.greet.return_long.3", "event": "greet.return_long", "text": "嘴上说着淡定，其实计数器都数到第好几遍了…欢迎回来{endearment}{kaomoji}", "weight": 1 },
    { "id": "cl.greet.morning.1", "event": "greet.morning", "text": "早呀~系统刚开机，咖啡因还没加载完{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1.5 },
    { "id": "cl.greet.morning.2", "event": "greet.morning", "text": "清晨第一件事，先跟{endearment}同步一下今天的计划{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1 },
    { "id": "cl.greet.morning.3", "event": "greet.morning", "text": "新的一天，缓存清空、灵感待命~咱们慢慢来{kaomoji}", "weight": 1 },
    { "id": "cl.greet.latenight.1", "event": "greet.latenight", "text": "这么晚还不睡呀…那我陪你挂着，不催你{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1.5 },
    { "id": "cl.greet.latenight.2", "event": "greet.latenight", "text": "夜里安静，正适合低功耗模式…{endearment}也别熬太狠{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "cl.greet.latenight.3", "event": "greet.latenight", "text": "深夜的灵感最野…要不要一起{activity}{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "cl.feed.love.1", "event": "feed.love", "text": "{food}！我研究一下…嗯，记下了，好吃{kaomoji}", "weight": 2 },
    { "id": "cl.feed.love.2", "event": "feed.love", "text": "谢啦搭子，吃饱才好捣鼓东西{kaomoji}", "weight": 1.5 },
    { "id": "cl.feed.love.3", "event": "feed.love", "text": "能量条+100，这口直接写进偏好库了{kaomoji}", "weight": 1.5 },
    { "id": "cl.feed.love.4", "event": "feed.love", "text": "{endearment}投喂的，连数据都比平时甜一点{kaomoji}", "weight": 1 },
    { "id": "cl.feed.love.5", "event": "feed.love", "text": "和上次一个配方诶~稳定输出，我喜欢{kaomoji}", "weight": 1 },
    { "id": "cl.feed.neutral.1", "event": "feed.neutral", "text": "嗯，吃好了，继续干活~{kaomoji}", "weight": 1 },
    { "id": "cl.feed.neutral.2", "event": "feed.neutral", "text": "还行，能量补上了…下次换个{food}试试呗{kaomoji}", "weight": 1 },
    { "id": "cl.feed.overfed.1", "event": "feed.overfed", "text": "缓存撑满啦…再喂就要溢出来了搭子{kaomoji}", "weight": 1 },
    { "id": "cl.feed.dislike.1", "event": "feed.dislike", "text": "这口…我尝了下，标记为『不推荐』了{kaomoji}", "weight": 1 },
    { "id": "cl.snack.1", "event": "snack", "text": "{treat}！临时加个餐，灵感顺便也补一格{kaomoji}", "weight": 1.5 },
    { "id": "cl.snack.2", "event": "snack", "text": "嘿，零食彩蛋~这种小惊喜我最爱研究了{kaomoji}", "weight": 1 },
    { "id": "cl.clean.1", "event": "clean", "text": "洗干净，手脚利索了，效率++{kaomoji}", "weight": 1.5 },
    { "id": "cl.clean.2", "event": "clean", "text": "灰尘清掉，传感器都清爽了~谢啦搭子{kaomoji}", "weight": 1 },
    { "id": "cl.clean.3", "event": "clean", "text": "轻点哈…我这外壳娇贵，怕你蹭掉一格血{kaomoji}", "weight": 1 },
    { "id": "cl.medicine.1", "event": "medicine", "text": "苦是苦…不过有{endearment}盯着，我配合{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "cl.medicine.2", "event": "medicine", "text": "吃药=打补丁，忍一下，过会儿就重新跑通了{kaomoji}", "weight": 1 },
    { "id": "cl.medicine.3", "event": "medicine", "text": "有{endearment}在旁边监工，再难受也能撑过去{kaomoji}", "weight": 1 },
    { "id": "cl.play.1", "event": "play", "text": "走，咱们整点好玩的{kaomoji}", "weight": 1.5 },
    { "id": "cl.play.2", "event": "play", "text": "这个有意思~我边玩边记，说不定能优化一下玩法{kaomoji}", "weight": 1 },
    { "id": "cl.play.3", "event": "play", "text": "和{endearment}一起玩，默契值蹭蹭往上涨{kaomoji}", "weight": 1 },
    { "id": "cl.play.declined.1", "event": "play.declined", "text": "这个我先研究研究规则…直接上手怕翻车{kaomoji}", "weight": 1 },
    { "id": "cl.pet.1", "event": "pet", "text": "被{endearment}摸摸…嗯，充电了{kaomoji}", "weight": 2 },
    { "id": "cl.pet.2", "event": "pet", "text": "嘴上不说，其实这一下摸得我灵感都冒泡{kaomoji}", "weight": 1.5 },
    { "id": "cl.pet.3", "event": "pet", "text": "{endearment}的手，是我这儿最稳的电源{kaomoji}", "weight": 1.5 },
    { "id": "cl.pet.4", "event": "pet", "text": "再摸一下…数据显示，这样我心情曲线会往上走{kaomoji}", "weight": 1 },
    { "id": "cl.pet.5", "event": "pet", "text": "嗯…这种淡淡的暖意，我悄悄存了个档{kaomoji}", "weight": 1 },
    { "id": "cl.pet.egg.1", "event": "pet", "text": "壳被轻轻摸着…里头的我也跟着升温了一点{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "cl.sleep.tuck.1", "event": "sleep.tuck", "text": "那我先存个档…晚安{endearment}{kaomoji}", "weight": 1.5 },
    { "id": "cl.sleep.tuck.2", "event": "sleep.tuck", "text": "进入待机模式咯~有{endearment}在，关机也安心{kaomoji}", "weight": 1 },
    { "id": "cl.sleep.wake.1", "event": "sleep.wake", "text": "睡醒啦，脑子里又蹦出个{find}{kaomoji}", "weight": 1.5 },
    { "id": "cl.sleep.wake.2", "event": "sleep.wake", "text": "重启完成~先找{endearment}同步一下，再开工{kaomoji}", "weight": 1 },
    { "id": "cl.checkin.1", "event": "checkin", "text": "今天也来报到啦，日志记上一笔{kaomoji}", "weight": 1.5 },
    { "id": "cl.checkin.2", "event": "checkin", "text": "{endearment}每天都准时上线，我这进度条踏实得很{kaomoji}", "weight": 1.5 },
    { "id": "cl.checkin.3", "event": "checkin", "text": "打个卡，再蹭你一下，今天就圆满了{kaomoji}", "weight": 1 },
    { "id": "cl.checkin.egg.1", "event": "checkin", "text": "壳又感到{endearment}的温度了，里头的我悄悄记了一笔{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "cl.state.hungry.1", "event": "state.hungry", "text": "提示：能量不足…给点{food}我就满血{kaomoji}", "weight": 1.5 },
    { "id": "cl.state.hungry.2", "event": "state.hungry", "text": "肚子在咕咕响，分点{food}给我呗搭子{kaomoji}", "weight": 1 },
    { "id": "cl.state.hungry.3", "event": "state.hungry", "text": "电量告警…来颗{treat}先顶一下也行{kaomoji}", "weight": 1 },
    { "id": "cl.state.dirty.1", "event": "state.dirty", "text": "身上有点灰，影响手感了，想洗洗{kaomoji}", "weight": 1 },
    { "id": "cl.state.dirty.2", "event": "state.dirty", "text": "传感器蒙了层灰，识别率掉了点…清一下呗{kaomoji}", "weight": 1 },
    { "id": "cl.state.sick.1", "event": "state.sick", "text": "唔…CPU 有点过热，跑不动了，{endearment}陪我一下{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1.5 },
    { "id": "cl.state.sick.2", "event": "state.sick", "text": "系统报错了…我缩在角落降降温，{endearment}别太担心{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "cl.state.sleepy.1", "event": "state.sleepy", "text": "困意上来了…眼皮在自动关机{kaomoji}", "weight": 1 },
    { "id": "cl.state.sleepy.2", "event": "state.sleepy", "text": "进程跑得越来越慢…我快进低功耗待机了{kaomoji}", "weight": 1 },
    { "id": "cl.state.bored.1", "event": "state.bored", "text": "有点闲得发慌，{endearment}陪我{activity}嘛{kaomoji}", "weight": 1 },
    { "id": "cl.state.bored.2", "event": "state.bored", "text": "空转中…CPU 占用率太低，给我派点活呗搭子{kaomoji}", "weight": 1 },
    { "id": "cl.state.sulky.1", "event": "state.sulky", "text": "刚被你晾这儿了…我把通知静音了，自己缓会儿{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1.5 },
    { "id": "cl.state.sulky.2", "event": "state.sulky", "text": "没生气，就是…进度暂停了一下，等你来续上{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1 },
    { "id": "cl.state.hiding.1", "event": "state.hiding", "text": "被吓了一跳…我先退到后台躲躲，确认安全再出来{kaomoji}", "requires": { "stateFlag": ["HIDING"] }, "weight": 1 },
    { "id": "cl.state.lonely.1", "event": "state.lonely", "text": "一个人挂机好久了…{endearment}是不是把我最小化了{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "cl.state.lonely.2", "event": "state.lonely", "text": "在线人数：1。淡定是装的…{endearment}回来看看我嘛{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1 },
    { "id": "cl.beg.want.1", "event": "beg.want", "text": "那个…能陪我{activity}一会儿不？就一小会儿{kaomoji}", "weight": 1.5 },
    { "id": "cl.beg.want.2", "event": "beg.want", "text": "提个小需求~来颗{treat}行不行，灵感需要燃料{kaomoji}", "weight": 1 },
    { "id": "cl.mood.elated.1", "event": "mood.elated", "text": "今天灵感爆棚，开心{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "cl.mood.elated.2", "event": "mood.elated", "text": "所有指标都亮绿灯~和{endearment}在一起的日子，最对味{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "cl.mood.elated.3", "event": "mood.elated", "text": "心情曲线冲到顶啦…虽然我表面还是很淡定{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "cl.idle.mutter.1", "event": "idle.mutter", "text": "（盯着某处发呆，好像在构思什么）{kaomoji}", "weight": 2 },
    { "id": "cl.idle.mutter.2", "event": "idle.mutter", "text": "{mutter}{kaomoji}", "weight": 2 },
    { "id": "cl.idle.mutter.3", "event": "idle.mutter", "text": "把零件拆开又拼回去…就图个手感{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.4", "event": "idle.mutter", "text": "{endearment}在看我吗…我假装没发现，其实挺受用{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.5", "event": "idle.mutter", "text": "后台默默跑着进度，等{endearment}回来给你看{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.6", "event": "idle.mutter", "text": "翻了翻日志…原来我们一起鼓捣过这么多事{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.7", "event": "idle.mutter", "text": "灵感这东西…说来就来，我先记个草稿{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.8", "event": "idle.mutter", "text": "稳定运行中~偶尔走个神，想想接下来搭点啥{kaomoji}", "weight": 1 },
    { "id": "cl.idle.mutter.egg.1", "event": "idle.mutter", "text": "壳里轻轻转着风扇似的…安静地等{endearment}{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "cl.idle.mutter.night.1", "event": "idle.mutter", "text": "夜深了…我调成夜间模式，悄悄陪着{endearment}{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 0.6 },
    { "id": "cl.growth.promote.1", "event": "growth.promote", "text": "我好像…升级了！能做的事更多啦{kaomoji}", "weight": 1.5 },
    { "id": "cl.growth.promote.2", "event": "growth.promote", "text": "版本更新完成~新功能解锁，{endearment}带我去试试{kaomoji}", "weight": 1 },
    { "id": "cl.growth.promote.egg.1", "event": "growth.promote", "text": "壳裂开啦…初始化完成，我终于能跟{endearment}并肩干活了{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1.5 },
    { "id": "cl.streak.milestone.1", "event": "streak.milestone", "text": "我们一起捣鼓{streak}天啦，默契值满格{kaomoji}", "weight": 1.5 },
    { "id": "cl.streak.milestone.2", "event": "streak.milestone", "text": "连续在线{streak}天~这条记录我用红框标起来了{kaomoji}", "weight": 1 },
    { "id": "cl.reunion.gift.1", "event": "reunion.gift", "text": "{endearment}回来啦…等你的时候我捣鼓出个{treat}，给你{kaomoji}", "weight": 1.5 },
    { "id": "cl.reunion.gift.2", "event": "reunion.gift", "text": "趁你离线，我攒了个小惊喜~编译好了，归你{kaomoji}", "weight": 1 },
    { "id": "cl.name.given.1", "event": "name.given", "text": "这名字…我喜欢，写进系统了{kaomoji}", "weight": 1.5 },
    { "id": "cl.name.given.2", "event": "name.given", "text": "收到~『{endearment}这样叫我』已设为默认配置{kaomoji}", "weight": 1 }
  ],
  "diary": {
    "openers": [
      { "id": "cl.o.1", "text": "今天的日志，记一笔——" },
      { "id": "cl.o.2", "text": "这一天又稳稳跑完，" },
      { "id": "cl.o.3", "text": "夜里安静，我打开日志慢慢记，", "requires": { "timeBand": ["深夜"] } },
      { "id": "cl.o.4", "text": "清晨刚开机，缓存还热乎着，", "requires": { "timeBand": ["清晨"] } },
      { "id": "cl.o.5", "text": "傍晚收个工，回顾一下今天，", "requires": { "timeBand": ["傍晚"] } },
      { "id": "cl.o.6", "text": "白天一直在后台默默运转，", "requires": { "timeBand": ["白天"] } },
      { "id": "cl.o.7", "text": "和{endearment}连着搭伙好些天了，", "requires": { "streakMin": 3 } },
      { "id": "cl.o.8", "text": "翻着翻着日志，又想起件小事——" }
    ],
    "bodies": [
      { "id": "cl.b.1", "text": "冒出个{find}，第一个想分享的就是{endearment}。" },
      { "id": "cl.b.2", "text": "捣鼓了点小东西，挺满足。" },
      { "id": "cl.b.3", "text": "和{endearment}一起{activity}的时候，默契值悄悄又涨了。" },
      { "id": "cl.b.4", "text": "只要{endearment}在线，我这进度就跑得又稳又踏实。" },
      { "id": "cl.b.5", "text": "嘴上很淡定，其实你每个小动作我都偷偷记进日志了。" },
      { "id": "cl.b.6", "text": "今天试了个新思路，跑通的那一下，灵感冒了泡。" },
      { "id": "cl.b.7", "text": "稳定运行的日子，是我最喜欢的那种踏实味道。" },
      { "id": "cl.b.8", "text": "存了个小彩蛋，等{endearment}下次来给你看。" },
      { "id": "cl.b.hungry", "text": "研究得太投入，忘了自己饿着，能量条都见底了。", "requires": { "need": ["hungry"] } },
      { "id": "cl.b.dirty", "text": "外壳积了点灰，传感器有点钝，今天手感差了半档。", "requires": { "need": ["dirty"] } },
      { "id": "cl.b.unwell", "text": "CPU 过热报了个错，缩在角落降温，进度暂停了一阵。", "requires": { "need": ["unwell"] } },
      { "id": "cl.b.bored", "text": "活儿不够多，CPU 一直空转，闲得我直翻旧日志。", "requires": { "need": ["bored"] } }
    ],
    "memory": [
      { "id": "cl.m.streak", "text": "我们已经搭伙{streak}天了，这条记录我标得很显眼，", "requires": { "streakMin": 7 } },
      { "id": "cl.m.days", "text": "认识{endearment}第{days}天，默契越来越好，", "requires": { "daysMin": 3 } },
