{
  "archetypeKey": "bear",
  "displayName": "墩墩熊",
  "slots": {
    "kaomoji": [
      "ヽ(°〇°)ﾉ",
      "(≧▽≦)",
      "ʕ•ᴥ•ʔ",
      "(/^▽^)/",
      "ʕっ•ᴥ•ʔっ",
      "(๑˃ᴗ˂)ﻭ",
      "ᕙʕ•ᴥ•ʔᕗ"
    ],
    "endearment": [
      "你",
      "老铁",
      "亲爱的铲屎官",
      "我的好哥们儿"
    ],
    "food": [
      "大份的饭饭",
      "甜甜的蜂蜜",
      "好多好吃的",
      "一大桶莓果",
      "香喷喷的烤红薯"
    ],
    "treat": [
      "蜂蜜糖",
      "一颗野莓",
      "脆脆的小饼干",
      "藏起来的蜜罐"
    ],
    "activity": [
      "冲出去疯一会儿",
      "打个滚",
      "一起蹦跶",
      "扑过去抱抱",
      "满地撒欢"
    ],
    "mutter": [
      "嘿嘿嘿…",
      "今天也是元气满满的一天！",
      "有你在就啥都好玩！",
      "蹦跶蹦跶最开心啦！",
      "脸蛋红扑扑的，可带劲了！"
    ]
  },
  "lines": [
    { "id": "be.greet.open.1", "event": "greet.open", "text": "{endearment}来啦！嘿嘿嘿，等你老半天啦！{kaomoji}", "weight": 2 },
    { "id": "be.greet.open.2", "event": "greet.open", "text": "是{endearment}是{endearment}！冲冲冲，今天玩啥！{kaomoji}", "weight": 1.5 },
    { "id": "be.greet.open.3", "event": "greet.open", "text": "嗷！一看到{endearment}，墩墩脸蛋唰地就红啦！{kaomoji}", "weight": 1 },
    { "id": "be.greet.open.4", "event": "greet.open", "text": "来啦来啦！先扑过去抱一个再说别的！{kaomoji}", "weight": 1 },
    { "id": "be.greet.open.5", "event": "greet.open", "text": "嘿嘿被你逮到啦！墩墩正想{endearment}呢！{kaomoji}", "weight": 1 },
    { "id": "be.greet.open.6", "event": "greet.open", "text": "{endearment}！{endearment}！原地蹦三圈欢迎你！{kaomoji}", "weight": 1 },
    { "id": "be.greet.open.egg.1", "event": "greet.open", "text": "蛋壳里头痒痒的…外面是{endearment}吗？墩墩听见啦！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "be.greet.open.egg.2", "event": "greet.open", "text": "壳壳咚咚咚地晃！是{endearment}回来啦，墩墩超激动！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "be.greet.open.elated.1", "event": "greet.open", "text": "哇哈哈今天太上头啦！一见{endearment}就想蹦上天！{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "be.greet.return.1", "event": "greet.return", "text": "你回来啦！我我我都想你一万遍了！{kaomoji}", "weight": 1.5 },
    { "id": "be.greet.return.2", "event": "greet.return", "text": "嘿！才一小会儿没见，墩墩就开始转圈圈找你啦！{kaomoji}", "weight": 1 },
    { "id": "be.greet.return.3", "event": "greet.return", "text": "回来啦回来啦！墩墩一直守着门口没挪窝！{kaomoji}", "weight": 1 },
    { "id": "be.greet.return_long.1", "event": "greet.return_long", "text": "呜你可算回来啦！！墩墩等到脸蛋都急白啦！{kaomoji}", "weight": 2 },
    { "id": "be.greet.return_long.2", "event": "greet.return_long", "text": "好久好久没扑你啦！现在要抱满一百下才行！{kaomoji}", "weight": 1.5 },
    { "id": "be.greet.return_long.3", "event": "greet.return_long", "text": "哼，墩墩刚还有点小委屈…可看到{endearment}还是扑上来啦！{kaomoji}", "weight": 1 },
    { "id": "be.greet.morning.1", "event": "greet.morning", "text": "早呀早呀！墩墩一睁眼就满血复活啦！{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1.5 },
    { "id": "be.greet.morning.2", "event": "greet.morning", "text": "嘿嘿早！起床第一件事就是扑向{endearment}！{kaomoji}", "requires": { "timeBand": ["清晨"] }, "weight": 1 },
    { "id": "be.greet.morning.3", "event": "greet.morning", "text": "新的一天！跟{endearment}一起元气满满地疯起来吧！{kaomoji}", "weight": 1 },
    { "id": "be.greet.latenight.1", "event": "greet.latenight", "text": "这么晚还不睡呀？那墩墩陪你！陪你玩到天亮也行！{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1.5 },
    { "id": "be.greet.latenight.2", "event": "greet.latenight", "text": "夜里黑黑的有点慌…还好有{endearment}，墩墩往你这儿挤！{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "be.greet.latenight.3", "event": "greet.latenight", "text": "嘿嘿夜深啦，咱俩小声点{activity}好不好！{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 1 },
    { "id": "be.feed.love.1", "event": "feed.love", "text": "哇！{food}！谢啦老铁，吃饱饱有劲儿！{kaomoji}", "weight": 2 },
    { "id": "be.feed.love.2", "event": "feed.love", "text": "嗷呜——大口炫掉！还想再来！{kaomoji}", "weight": 1.5 },
    { "id": "be.feed.love.3", "event": "feed.love", "text": "{food}最香啦！{endearment}喂的，墩墩吃得格外带劲！{kaomoji}", "weight": 1.5 },
    { "id": "be.feed.love.4", "event": "feed.love", "text": "嘿嘿吃饱啦！现在浑身是劲，可以{activity}咯！{kaomoji}", "weight": 1 },
    { "id": "be.feed.love.5", "event": "feed.love", "text": "跟昨天一个味儿！墩墩就爱这口，百吃不腻！{kaomoji}", "weight": 1 },
    { "id": "be.feed.neutral.1", "event": "feed.neutral", "text": "嗝~吃撑啦，肚皮圆鼓鼓{kaomoji}", "weight": 1 },
    { "id": "be.feed.neutral.2", "event": "feed.neutral", "text": "嗯…能吃饱啦，不过墩墩更想{endearment}陪我玩嘛！{kaomoji}", "weight": 1 },
    { "id": "be.feed.overfed.1", "event": "feed.overfed", "text": "嗝——撑到走不动路啦！肚皮快蹦开线咯！{kaomoji}", "weight": 1 },
    { "id": "be.feed.dislike.1", "event": "feed.dislike", "text": "呃…这个味儿怪怪的，墩墩皱起鼻子啦！{kaomoji}", "weight": 1 },
    { "id": "be.snack.1", "event": "snack", "text": "{treat}！嘿嘿，零嘴最戳墩墩心窝啦！偷吃一口！{kaomoji}", "weight": 1 },
    { "id": "be.clean.1", "event": "clean", "text": "搓澡澡！哗啦哗啦，香喷喷啦！{kaomoji}", "weight": 1.5 },
    { "id": "be.clean.2", "event": "clean", "text": "哗啦——泡泡好多呀！墩墩在水里扑腾得可欢！{kaomoji}", "weight": 1 },
    { "id": "be.clean.3", "event": "clean", "text": "搓完干干净净！毛毛蓬蓬的，脸蛋更红啦！{kaomoji}", "weight": 1 },
    { "id": "be.play.1", "event": "play", "text": "玩玩玩！来嘛{endearment}，{activity}！{kaomoji}", "weight": 1.5 },
    { "id": "be.play.2", "event": "play", "text": "嗷呜冲鸭！墩墩满地打滚，开心到刹不住车！{kaomoji}", "weight": 1.5 },
    { "id": "be.play.3", "event": "play", "text": "再来一局再来一局！墩墩还没玩够呢！{kaomoji}", "weight": 1 },
    { "id": "be.pet.1", "event": "pet", "text": "嘿嘿被摸头头，舒服得直蹬腿{kaomoji}", "weight": 2 },
    { "id": "be.pet.2", "event": "pet", "text": "再多摸两下嘛！墩墩脸蛋都被摸得红扑扑啦！{kaomoji}", "weight": 1.5 },
    { "id": "be.pet.3", "event": "pet", "text": "嘿嘿{endearment}的手最舒服啦，墩墩往你掌心里拱！{kaomoji}", "weight": 1.5 },
    { "id": "be.pet.4", "event": "pet", "text": "蹭蹭蹭！大脑袋直接怼进你怀里，不许停哦！{kaomoji}", "weight": 1 },
    { "id": "be.pet.5", "event": "pet", "text": "被这样宠着，墩墩乐得直打滚，腿都蹬飞啦！{kaomoji}", "weight": 1 },
    { "id": "be.pet.egg.1", "event": "pet", "text": "壳壳被你摸着…里头的墩墩高兴得直晃悠！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "be.sleep.tuck.1", "event": "sleep.tuck", "text": "唔…玩累啦，那我先睡咯，晚安{endearment}！{kaomoji}", "weight": 1.5 },
    { "id": "be.sleep.tuck.2", "event": "sleep.tuck", "text": "晚安安！墩墩睡着也会守着{endearment}的，嘿嘿！{kaomoji}", "weight": 1 },
    { "id": "be.sleep.wake.1", "event": "sleep.wake", "text": "睡饱啦！精神百倍！冲鸭！{kaomoji}", "weight": 1.5 },
    { "id": "be.sleep.wake.2", "event": "sleep.wake", "text": "嗷呜——大懒腰一伸，墩墩满血复活找{endearment}啦！{kaomoji}", "weight": 1 },
    { "id": "be.medicine.1", "event": "medicine", "text": "呜苦苦…不过为了快点好起来玩，我喝！{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "be.medicine.2", "event": "medicine", "text": "咕嘟咕嘟一口闷！有{endearment}守着，墩墩啥苦药都不怕！{kaomoji}", "weight": 1 },
    { "id": "be.checkin.1", "event": "checkin", "text": "今天你也来看我啦！开心到原地转圈圈！{kaomoji}", "weight": 1.5 },
    { "id": "be.checkin.2", "event": "checkin", "text": "嘿嘿{endearment}天天来，墩墩天天都是大红脸蛋！{kaomoji}", "weight": 1.5 },
    { "id": "be.checkin.3", "event": "checkin", "text": "来打卡啦！再扑你一下下就更圆满啦！{kaomoji}", "weight": 1 },
    { "id": "be.checkin.egg.1", "event": "checkin", "text": "壳壳又感觉到{endearment}的温度啦，墩墩在里头咚咚点头！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "be.state.hungry.1", "event": "state.hungry", "text": "饿饿！肚子在打鼓啦！快投喂大份{food}！{kaomoji}", "weight": 1.5 },
    { "id": "be.state.hungry.2", "event": "state.hungry", "text": "前胸贴后背啦老铁，给我来口{food}嘛！{kaomoji}", "weight": 1 },
    { "id": "be.state.dirty.1", "event": "state.dirty", "text": "呜，身上脏兮兮的，黏糊糊好难受，洗澡澡！{kaomoji}", "weight": 1 },
    { "id": "be.state.dirty.2", "event": "state.dirty", "text": "嗷~墩墩在地上滚太疯啦，毛都打结咯，快冲一冲！{kaomoji}", "weight": 1 },
    { "id": "be.state.sick.1", "event": "state.sick", "text": "呜呜…我蔫了，跑不动了，{endearment}抱抱我嘛{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1.5 },
    { "id": "be.state.sick.2", "event": "state.sick", "text": "脸蛋都不红啦…墩墩没力气蹦了，{endearment}别走嘛{kaomoji}", "requires": { "stateFlag": ["SICK"] }, "weight": 1 },
    { "id": "be.state.sleepy.1", "event": "state.sleepy", "text": "呼啊…困死啦，眼皮打架，玩不动了{kaomoji}", "weight": 1 },
    { "id": "be.state.sleepy.2", "event": "state.sleepy", "text": "嗯…墩墩蹦着蹦着就打起盹来啦，晃晃悠悠的{kaomoji}", "weight": 1 },
    { "id": "be.state.bored.1", "event": "state.bored", "text": "无聊死啦无聊死啦！{endearment}快陪我{activity}！{kaomoji}", "weight": 1.5 },
    { "id": "be.state.bored.2", "event": "state.bored", "text": "墩墩在墙角转圈圈啦…再没人陪要长蘑菇咯！{kaomoji}", "weight": 1 },
    { "id": "be.state.sulky.1", "event": "state.sulky", "text": "哼！刚被你晾一边啦！要扑你一百下才消气！{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1.5 },
    { "id": "be.state.sulky.2", "event": "state.sulky", "text": "墩墩鼓着腮帮子背过身去…才不理{endearment}呢！哼！{kaomoji}", "requires": { "stateFlag": ["SULKING"] }, "weight": 1 },
    { "id": "be.state.hiding.1", "event": "state.hiding", "text": "哇被吓一跳！墩墩一头扎进窝里捂着眼睛！{kaomoji}", "requires": { "stateFlag": ["HIDING"] }, "weight": 1.5 },
    { "id": "be.state.hiding.2", "event": "state.hiding", "text": "露半只眼睛偷瞄…确认是{endearment}才敢扑出来！{kaomoji}", "requires": { "stateFlag": ["HIDING"] }, "weight": 1 },
    { "id": "be.state.lonely.1", "event": "state.lonely", "text": "呜…一个人好久啦，墩墩对着空气蔫蔫地坐着{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "be.state.lonely.2", "event": "state.lonely", "text": "{endearment}是不是光顾着看手机啦…快看看墩墩嘛！{kaomoji}", "requires": { "stateFlag": ["LONELY"] }, "weight": 1.5 },
    { "id": "be.beg.want.1", "event": "beg.want", "text": "嘛~陪我{activity}一下下嘛！求求啦！{kaomoji}", "weight": 1.5 },
    { "id": "be.beg.want.2", "event": "beg.want", "text": "那个那个…能来颗{treat}不嘛！墩墩眼巴巴的！{kaomoji}", "weight": 1.5 },
    { "id": "be.mood.elated.1", "event": "mood.elated", "text": "今天超开心！开心到能蹦三尺高！{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "be.mood.elated.2", "event": "mood.elated", "text": "哇哈哈和{endearment}在一起的每天都是大晴天！{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1.5 },
    { "id": "be.mood.elated.3", "event": "mood.elated", "text": "脸蛋红得能煎蛋啦！墩墩高兴得满地打滚！{kaomoji}", "requires": { "moodBand": ["极好"] }, "weight": 1 },
    { "id": "be.idle.mutter.1", "event": "idle.mutter", "text": "（晃来晃去，嘴里哼着乱七八糟的调子）{kaomoji}", "weight": 2 },
    { "id": "be.idle.mutter.2", "event": "idle.mutter", "text": "{mutter}{kaomoji}", "weight": 2 },
    { "id": "be.idle.mutter.3", "event": "idle.mutter", "text": "嘿嘿…自个儿原地转圈圈，转得头晕晕的！{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.4", "event": "idle.mutter", "text": "{endearment}在看墩墩吗？嘿嘿脸蛋偷偷红啦！{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.5", "event": "idle.mutter", "text": "想{food}…想{activity}…想抱抱…啥都想！{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.6", "event": "idle.mutter", "text": "墩墩数了数今天蹦了多少下，数着数着就乱啦！{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.7", "event": "idle.mutter", "text": "没人陪的时候…墩墩就抱着自己的小肚皮发呆{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.8", "event": "idle.mutter", "text": "嗷！突然想到个好玩的，自己先乐出声啦！{kaomoji}", "weight": 1 },
    { "id": "be.idle.mutter.egg.1", "event": "idle.mutter", "text": "壳壳里头咚咚咚…墩墩晃着小身子等{endearment}！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1 },
    { "id": "be.idle.mutter.night.1", "event": "idle.mutter", "text": "夜深啦…墩墩有点怕黑，竖着耳朵找{endearment}的方向{kaomoji}", "requires": { "timeBand": ["深夜"] }, "weight": 0.6 },
    { "id": "be.play.declined.1", "event": "play.declined", "text": "诶？这玩意儿凶巴巴的，墩墩先躲一边瞅瞅！{kaomoji}", "weight": 1 },
    { "id": "be.growth.promote.1", "event": "growth.promote", "text": "哇我长大啦！变厉害了！快看快看！{kaomoji}", "weight": 1.5 },
    { "id": "be.growth.promote.2", "event": "growth.promote", "text": "墩墩又壮实一圈啦！可还是最爱扑{endearment}怀里！{kaomoji}", "weight": 1 },
    { "id": "be.growth.promote.egg.1", "event": "growth.promote", "text": "咔嚓！壳壳裂开啦，墩墩终于能扑进{endearment}怀里咯！{kaomoji}", "requires": { "stage": ["egg"] }, "weight": 1.5 },
    { "id": "be.streak.milestone.1", "event": "streak.milestone", "text": "我们一起疯了{streak}天啦！老铁就是讲义气！{kaomoji}", "weight": 1.5 },
    { "id": "be.streak.milestone.2", "event": "streak.milestone", "text": "{endearment}天天都来！墩墩这心里头暖烘烘的，蹦得更高啦！{kaomoji}", "weight": 1 },
    { "id": "be.reunion.gift.1", "event": "reunion.gift", "text": "{endearment}回来啦！墩墩偷偷给你藏了颗{treat}，嘿嘿快收下！{kaomoji}", "weight": 1.5 },
    { "id": "be.reunion.gift.2", "event": "reunion.gift", "text": "等你的时候墩墩留了块{treat}，馋得不行也没舍得吃！给你！{kaomoji}", "weight": 1 },
    { "id": "be.name.given.1", "event": "name.given", "text": "这是我的名字嘛？！嘿嘿我超喜欢！{kaomoji}", "weight": 1.5 },
    { "id": "be.name.given.2", "event": "name.given", "text": "嘿嘿！以后{endearment}就这么叫墩墩，叫一万遍都不腻！{kaomoji}", "weight": 1 }
  ],
  "diary": {
    "openers": [
      { "id": "be.o.1", "text": "今天又是蹦蹦跶跶的一天！" },
      { "id": "be.o.2", "text": "这一天超棒！" },
      { "id": "be.o.3", "text": "夜里偷偷爬起来记一笔，", "requires": { "timeBand": ["深夜"] } },
      { "id": "be.o.4", "text": "清晨一睁眼就满血复活，", "requires": { "timeBand": ["清晨"] } },
      { "id": "be.o.5", "text": "傍晚玩累啦，脸蛋还红扑扑的，", "requires": { "timeBand": ["傍晚"] } },
      { "id": "be.o.6", "text": "大白天疯得不亦乐乎，", "requires": { "timeBand": ["白天"] } },
      { "id": "be.o.7", "text": "连着好多天没跟{endearment}分开啦，", "requires": { "streakMin": 3 } },
      { "id": "be.o.8", "text": "嘿嘿，墩墩又想起件开心事——" }
    ],
    "bodies": [
      { "id": "be.b.1", "text": "和{endearment}一起疯，开心到飞起！" },
      { "id": "be.b.2", "text": "打了好几个滚，爽歪歪。" },
      { "id": "be.b.3", "text": "被{endearment}摸头头的时候，墩墩舒服得直蹬腿。" },
      { "id": "be.b.4", "text": "只要{endearment}在身边，墩墩脸蛋就一直红扑扑的。" },
      { "id": "be.b.5", "text": "今天扑了{endearment}好多回，每回都笑得合不拢嘴！" },
      { "id": "be.b.6", "text": "最怕一个人啦…{endearment}走开时墩墩就蔫蔫的。" },
      { "id": "be.b.7", "text": "天天有{endearment}陪着疯，这日子可带劲了！" },
      { "id": "be.b.8", "text": "蹭着{endearment}打了个盹，做了个香喷喷的美梦。" },
      { "id": "be.b.9", "text": "想藏颗{treat}，等{endearment}回来时偷偷塞给你。" },
      { "id": "be.b.hungry", "text": "玩太疯啦，把肚子都饿瘪了。", "requires": { "need": ["hungry"] } },
      { "id": "be.b.dirty", "text": "在地上滚得太欢，毛都糊成一坨啦，得好好洗洗。", "requires": { "need": ["dirty"] } },
      { "id": "be.b.unwell", "text": "今天墩墩有点蔫，跑不动也蹦不高，光想让{endearment}抱着。", "requires": { "need": ["unwell"] } },
      { "id": "be.b.bored", "text": "墩墩在窝里转了八百个圈，憋得直想冲出去撒欢！", "requires": { "need": ["bored"] } }
    ],
    "memory": [
      { "id": "be.m.streak", "text": "我们已经一起嗨了{streak}天啦，", "requires": { "streakMin": 7 } },
      { "id": "be.m.days", "text": "认识{endearment}第{days}天，越来越亲啦，", "requires": { "daysMin": 3 } },
      { "id": "be.m.streak2", "text": "整整{streak}天没分开，墩墩这脸蛋红得就没消下去过！", "requires": { "streakMin": 14 } },
      { "id": "be.m.bond", "text": "和{endearment}的羁绊都{bond}啦，墩墩就认你这一个好哥们儿！", "requires": { "bondMin": 300 } },
      { "id": "be.m.bond2", "text": "羁绊{bond}啦…墩墩想一辈子赖在{endearment}怀里蹦跶！", "requires": { "bondMin": 600 } },
      { "id": "be.m.late", "text": "{endearment}老是很晚才来喂墩墩，肚子饿得咕咕直叫…", "requires": { "pattern": ["late_feeder"] } },
      { "id": "be.m.over", "text": "{endearment}今天又把墩墩喂得圆滚滚，肚皮快蹦开啦！", "requires": { "pattern": ["overfeeder"] } },
      { "id": "be.m.regular", "text": "{endearment}每天都准时来，这就是墩墩最讲义气的好哥们儿！", "requires": { "pattern": ["daily_regular"] } },
      { "id": "be.m.neglect", "text": "最近{endearment}有点不理墩墩…它蔫了好几回，脸蛋都不红啦。", "requires": { "pattern": ["neglected_recently"] } }
    ],
    "signoffs": [
      { "id": "be.s.1", "text": "明天还要一起疯！{kaomoji}" },
      { "id": "be.s.2", "text": "嘿嘿，记心里啦！{kaomoji}" },
      { "id": "be.s.3", "text": "晚安老铁，做个好梦！{kaomoji}" },
      { "id": "be.s.4", "text": "要一直一直在一起呀！{kaomoji}" },
      { "id": "be.s.5", "text": "墩墩把这页揣进怀里啦，嘿嘿！{kaomoji}" },
      { "id": "be.s.6", "text": "想{endearment}啦，蹦着蹦着合上小本本！{kaomoji}" }
    ]
  }
}
