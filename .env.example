# Copy to web/.env and fill in. web/.env is gitignored.

# Postgres password for the cloudpet role. Generated once and stored in
# /home/liharr/.config/cloudpet.env; copy the same value here.
PG_PASSWORD=

# WeChat mini program credentials. Both required for the real wx.login flow.
# Get these from mp.weixin.qq.com after registering the mini program.
# If left blank, the backend falls back to anonymous mode (generates a
# random user id) — useful for local dev before the AppID is registered.
WX_APP_ID=
WX_APP_SECRET=

# Optional: Umami pageview analytics for the landing page at /cloudpet.
# Both required to render the tracking script; either missing → skipped.
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
