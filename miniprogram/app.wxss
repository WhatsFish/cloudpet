/* Cozy, warm, rounded global theme. */

page {
  background: #FFF7E6;
  color: #4A3F35;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.page { padding: 32rpx 32rpx 120rpx; }

.muted { color: #A89B8C; }
.subtle { color: #8A7D6E; }
.center { text-align: center; }

.card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(180, 150, 110, 0.10);
}

.title { font-size: 40rpx; font-weight: 700; }
.label { font-size: 24rpx; color: #A89B8C; margin-bottom: 10rpx; letter-spacing: 0.5rpx; }

.btn {
  background: #E8845B;
  color: #FFF;
  border-radius: 999rpx;
  padding: 26rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}
.btn--ghost { background: #FFF0E0; color: #E8845B; }
.btn--block { display: block; width: 100%; box-sizing: border-box; }
.btn[disabled], .btn.is-disabled { background: #EDE4D6; color: #B9AC9A; }

.pixel { image-rendering: pixelated; -ms-interpolation-mode: nearest-neighbor; }

.bubble {
  position: relative;
  background: #FFFDF7;
  border: 2rpx solid #F0E2CC;
  border-radius: 24rpx;
  padding: 22rpx 26rpx;
  font-size: 28rpx;
  color: #5A4E42;
  box-shadow: 0 4rpx 14rpx rgba(180, 150, 110, 0.08);
}
.bubble::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -14rpx;
  margin-left: -12rpx;
  border: 12rpx solid transparent;
  border-top-color: #FFFDF7;
}

.chip {
  display: inline-block;
  background: #FFF0E0;
  color: #C9763F;
  border-radius: 999rpx;
  padding: 6rpx 18rpx;
  font-size: 22rpx;
  margin-right: 10rpx;
}
.badge {
  display: inline-block;
  background: #FFE9E9;
  color: #D8635A;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  margin: 0 8rpx 8rpx 0;
}

.empty { padding: 120rpx 0; text-align: center; color: #A89B8C; }
