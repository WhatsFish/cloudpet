<view class="screen theme-{{theme}}" wx:if="{{pet}}">
  <view class="device">
    <view class="brand">● {{pet.pet.name}} · {{stageLabel}} ●</view>

    <view class="lcd">
      <image class="bg" src="{{bgSrc}}" mode="aspectFill" />
      <view class="lcd-grid"></view>

      <view class="road" bindtap="onC">
        <text class="lvchip">Lv{{levelNum}}</text>
        <view class="lvbar"><view class="lvfill" style="width:{{levelPct}}%"></view></view>
        <text class="roadtxt">{{roadmapLine}}</text>
      </view>

      <view class="stage-wrap" bindtap="onPet">
        <view class="sprite-scale" style="transform:scale({{spriteScale}})">
          <image class="sprite {{animClass}}" src="{{spriteSrc}}" mode="aspectFit" binderror="onSpriteError" />
        </view>
        <view wx:for="{{particles}}" wx:key="key" class="particle" style="left:{{item.x}}rpx; --rot:{{item.rot}}deg; animation-delay:{{item.delay}}ms">{{item.emoji}}</view>
        <view wx:if="{{floatTag}}" class="floattag">{{floatTag}}</view>
        <view wx:if="{{asleepNow}}" class="zzz">z z Z</view>
      </view>

      <view class="metarow">
        <view class="hearts">
          <text wx:for="{{hearts}}" wx:key="*this" class="heart {{item ? 'on' : ''}}">{{item ? '♥' : '♡'}}</text>
          <text class="bondlab">亲密</text>
        </view>
        <text class="growth">📈+{{growthPerDay}}/天 · ⚖️{{weightKg}}kg</text>
      </view>

      <view class="needcard" bindtap="onPet">{{needCard}}</view>
    </view>

    <view class="sparkbar {{sparkN > 0 ? 'sparkbar--on' : ''}}" bindtap="onSpark">
      <text class="spark-emoji">✨</text>
      <text class="spark-text">{{sparkText}}</text>
      <text wx:if="{{sparkN > 0}}" class="spark-n">×{{sparkN}}</text>
    </view>

    <view class="handle" bindtap="toggleDrawer">{{showDrawer ? '收起 ▾' : '更多操作 ▸'}}</view>
    <view class="drawer {{showDrawer ? 'open' : ''}}">
      <view class="drow-lab">照顾（按它的需求来 · 满足需求才长得快）</view>
      <view class="dacts">
        <view wx:for="{{careActs}}" wx:key="verb" class="dact {{item.due ? 'dact--due' : ''}} {{item.enabled ? '' : 'dact--off'}}" data-verb="{{item.verb}}" bindtap="onDrawerAction">
          <text class="de">{{item.emoji}}</text><text class="dl">{{item.label}}</text>
          <text class="dsub">{{item.sub}}</text>
        </view>
      </view>
      <view class="drow-lab">陪伴（随时 · 免费 · 涨亲密，不影响形态）</view>
      <view class="dacts">
        <view wx:for="{{funActs}}" wx:key="verb" class="dact {{item.enabled ? '' : 'dact--off'}}" data-verb="{{item.verb}}" bindtap="onDrawerAction">
          <text class="de">{{item.emoji}}</text><text class="dl">{{item.label}}</text>
        </view>
      </view>
      <view class="dchips">
        <view class="dchip" bindtap="openStatus">📊 状态</view>
        <view class="dchip" bindtap="goDiary">📓 心声</view>
        <view class="dchip" bindtap="goCodex">📖 图鉴</view>
        <view class="dchip" bindtap="openSettings">⚙️ 设置</view>
      </view>
    </view>

    <view class="buttons">
      <view class="abtn {{aGlow ? 'abtn--need' : ''}} {{aVerb ? '' : 'abtn--off'}}" bindtap="onA">
        <text class="abk">A</text>
        <text class="abe">{{aEmoji}}</text>
        <text class="abl">{{aLabel}}</text>
        <text wx:if="{{aReward}}" class="abr">{{aReward}}</text>
      </view>
      <view class="abtn" bindtap="onB">
        <text class="abk">B</text>
        <text class="abe">{{bEmoji}}</text>
        <text class="abl">{{bLabel}}</text>
      </view>
      <view class="abtn {{pet.fork.pending ? 'abtn--need' : ''}}" bindtap="onC">
        <text class="abk">C</text>
        <text class="abe">🧬</text>
        <text class="abl">{{pet.fork.pending ? '可进化' : '路线'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{recap}}" class="mask" bindtap="dismissRecap">
    <view class="recap" catchtap="noop">
      <view class="recap-title">我长大啦！</view>
      <image class="recap-sprite" src="{{spriteSrc}}" mode="aspectFit" binderror="onSpriteError" />
      <view class="recap-line">{{recap.line}}</view>
      <view class="recap-meta"><block wx:if="{{recap.levelTo > recap.levelFrom}}">Lv{{recap.levelFrom}} → Lv{{recap.levelTo}} </block><block wx:if="{{recap.evolvedToName}}">长成「{{recap.evolvedToName}}」</block></view>
      <view class="recap-btn" bindtap="dismissRecap">抱抱它 💛</view>
    </view>
  </view>

  <view wx:if="{{showRoadmap}}" class="mask" bindtap="closeModals">
    <view class="panel" catchtap="noop">
      <view class="panel-title">成长路线</view>
      <view class="road-big">{{roadmapLine}}</view>
      <view class="srow2" wx:if="{{pet.roadmap.stage}}">下一阶段「{{pet.roadmap.stage.towardName}}」：经验差 {{pet.roadmap.stage.expRemaining}} · 还要 {{pet.roadmap.stage.daysRemaining}} 天 · 亲密差 {{pet.roadmap.stage.bondRemaining}}</view>
      <view class="srow2">每天自然成长约 +{{growthPerDay}} 经验（养得越好长得越快）</view>
      <view class="srow2">长成少年时，它的样子由你亲手选（本形 / 3 种近缘形态，4 选 1）</view>
      <view class="srow2">亲密度 {{pet.bond}}/1000 · 连续 {{pet.streakDays}} 天</view>
      <view wx:if="{{pet.fork.pending}}" class="fork-open" bindtap="openFork">✨ 它准备好长大了，选择它的样子 →</view>
      <view class="pbtn" bindtap="closeModals">知道啦</view>
    </view>
  </view>

  <view wx:if="{{showFork}}" class="mask" bindtap="closeFork">
    <view class="forkpanel" catchtap="noop">
      <view class="fork-title">它准备好长大啦！</view>
      <view class="fork-sub">你希望它长成哪一种？随你喜欢，和怎么照顾它无关 · 选定后就不能再改咯～</view>
      <view class="fork-grid">
        <view wx:for="{{forkOptions}}" wx:key="branch" class="fork-card" data-branch="{{item.branch}}" bindtap="chooseFork">
          <image class="fork-img" src="{{item.sprite}}" mode="aspectFit" binderror="onSpriteError" />
          <view class="fork-name">{{item.name}}</view>
          <view class="fork-blurb">{{item.blurb}}</view>
        </view>
      </view>
      <view class="fork-cancel" bindtap="closeFork">我再想想</view>
    </view>
  </view>

  <view wx:if="{{showStatus}}" class="mask" bindtap="closeModals">
    <view class="panel" catchtap="noop">
      <view class="panel-title">状态 · {{pet.pet.name}}</view>
      <view wx:for="{{statBars}}" wx:key="label" class="srow">
        <text class="slabel">{{item.label}}</text>
        <view class="sbar"><view class="sfill" style="width:{{item.pct}}%;background:{{item.color}}"></view></view>
        <text class="sval">{{item.value}}</text>
      </view>
      <view class="srow2">体重 {{weightKg}} kg（每天一点点长大）· 认识第 {{pet.pet.daysKnown}} 天</view>
      <view class="srow2">亲密度 {{pet.bond}}/1000 · 连续 {{pet.streakDays}} 天</view>
      <view class="pbtn" bindtap="closeModals">关闭</view>
    </view>
  </view>

  <view wx:if="{{showSettings}}" class="mask" bindtap="closeModals">
    <view class="panel" catchtap="noop">
      <view class="panel-title">设置</view>
      <view class="plabel">机身配色</view>
      <view class="themes">
        <view wx:for="{{['cream','mint','dusk']}}" wx:key="*this" class="swatch theme-{{item}} {{theme === item ? 'sel' : ''}}" data-theme="{{item}}" bindtap="pickTheme">
          <view class="swatch-shell"></view>
          <text class="swatch-name">{{item === 'cream' ? '奶油' : item === 'mint' ? '薄荷' : '暮光'}}</text>
        </view>
      </view>
      <view class="plabel">给它改名</view>
      <view class="namerow">
        <input class="ninput" value="{{nameInput}}" maxlength="12" bindinput="onNameInput" />
        <view class="nbtn" bindtap="saveName">保存</view>
      </view>
      <view class="pbtn" bindtap="closeModals">关闭</view>
    </view>
  </view>
</view>

<view class="screen theme-cream center-screen" wx:elif="{{error}}">
  <view class="muted">{{error}}</view>
  <view class="retry" bindtap="load">再试一次</view>
</view>
<view class="screen theme-cream center-screen" wx:else>
  <view class="muted">正在唤醒你的小宠…</view>
</view>
