/* pixel font everywhere (loaded global in app.ts; falls back gracefully) */
page { font-family: "Zpix", "PingFang SC", -apple-system, "Microsoft YaHei", sans-serif; background:var(--bg); }

/* ===== theme palettes (app scene + accent) ===== */
.theme-cream { --bg:#FBF1DC; --card:#FFFDF7; --ink:#5A4A3A; --soft:#A89B8C; --line:#EFE3CE; --accent:#E07A52; --accent-soft:#FBE6DC; --scene1:#FCEBD3; --scene2:#CFE9F2; }
.theme-mint  { --bg:#E9F5F0; --card:#FBFFFD; --ink:#3E5A50; --soft:#8FACA2; --line:#D6EBE2; --accent:#3FA98C; --accent-soft:#DBF0E9; --scene1:#E7F6EE; --scene2:#CDEBF0; }
.theme-dusk  { --bg:#F0ECF7; --card:#FCFAFF; --ink:#4E4360; --soft:#9F92B4; --line:#E5DCF2; --accent:#9A6FD0; --accent-soft:#ECE2FA; --scene1:#EFE6FA; --scene2:#D6DCF2; }

.app { min-height:100vh; background:var(--bg); box-sizing:border-box; padding:20rpx 24rpx 48rpx; display:flex; flex-direction:column; gap:18rpx; }
.center-screen { justify-content:center; align-items:center; gap:28rpx; }
.muted { color:var(--soft); font-size:28rpx; }

/* ===== top bar ===== */
.topbar { display:flex; align-items:center; justify-content:space-between; padding:4rpx 4rpx 0; }
.title { display:flex; align-items:baseline; gap:14rpx; }
.pname { font-size:38rpx; font-weight:800; color:var(--ink); }
.pstage { font-size:22rpx; color:var(--accent); background:var(--accent-soft); border-radius:999rpx; padding:3rpx 14rpx; }
.gear { width:60rpx; height:60rpx; border-radius:999rpx; background:var(--card); color:var(--soft); font-size:34rpx; display:flex; align-items:center; justify-content:center; box-shadow:0 4rpx 12rpx rgba(120,90,50,0.10); }

/* ===== hero scene ===== */
.scene { position:relative; height:460rpx; border-radius:36rpx; overflow:hidden; background:linear-gradient(180deg,var(--scene1),var(--scene2)); box-shadow:0 12rpx 32rpx rgba(120,90,50,0.16); }
.bg { position:absolute; inset:0; width:100%; height:100%; image-rendering:pixelated; opacity:0.96; }
.lv-badge { position:absolute; left:20rpx; top:20rpx; z-index:3; background:rgba(255,255,255,0.85); border-radius:16rpx; padding:8rpx 14rpx; display:flex; flex-direction:column; gap:6rpx; box-shadow:0 4rpx 10rpx rgba(80,60,40,0.12); }
.lv-txt { font-size:24rpx; font-weight:800; color:var(--accent); }
.lv-bar { width:120rpx; height:8rpx; background:rgba(120,100,80,0.22); border-radius:999rpx; overflow:hidden; }
.lv-fill { height:100%; background:var(--accent); border-radius:999rpx; transition:width 0.4s ease; }
.bond-badge { position:absolute; right:20rpx; top:20rpx; z-index:3; background:rgba(255,255,255,0.85); border-radius:999rpx; padding:6rpx 14rpx; box-shadow:0 4rpx 10rpx rgba(80,60,40,0.12); }
.heart { font-size:26rpx; color:rgba(150,120,120,0.32); margin:0 1rpx; }
.heart.on { color:#E8607A; }

.stage-wrap { position:absolute; left:0; right:0; top:44rpx; bottom:96rpx; z-index:2; display:flex; justify-content:center; align-items:flex-end; }
.sprite { width:280rpx; height:280rpx; image-rendering:pixelated; -ms-interpolation-mode:nearest-neighbor; }
.particle { position:absolute; top:90rpx; font-size:42rpx; animation:floatburst 1s ease-out forwards; }
@keyframes floatburst { 0%{transform:translateY(24rpx) scale(0.4) rotate(0);opacity:0;} 22%{opacity:1;} 100%{transform:translateY(-150rpx) scale(1.15) rotate(var(--rot,0));opacity:0;} }
.floattag { position:absolute; top:30rpx; right:30rpx; z-index:4; font-size:26rpx; font-weight:700; color:var(--accent); background:rgba(255,255,255,0.9); border-radius:12rpx; padding:4rpx 14rpx; animation:floatup 1.1s ease-out forwards; }
@keyframes floatup { 0%{transform:translateY(0) scale(0.5);opacity:0;} 25%{opacity:1;transform:translateY(-12rpx) scale(1);} 100%{transform:translateY(-80rpx) scale(1);opacity:0;} }
.zzz { position:absolute; top:60rpx; right:60rpx; z-index:4; font-size:32rpx; color:#8FA0C8; letter-spacing:4rpx; animation:zzzfloat 2.4s ease-in-out infinite; }
@keyframes zzzfloat { 0%,100%{transform:translateY(0);opacity:0.5;} 50%{transform:translateY(-8rpx);opacity:1;} }

.speech { position:absolute; left:24rpx; right:24rpx; bottom:18rpx; z-index:3; background:rgba(255,255,255,0.92); border:2rpx solid rgba(120,90,50,0.10); border-radius:20rpx; padding:14rpx 20rpx; font-size:25rpx; line-height:1.45; color:var(--ink); text-align:center; box-shadow:0 4rpx 14rpx rgba(80,60,40,0.10); }

/* ===== cards ===== */
.card { background:var(--card); border-radius:28rpx; padding:22rpx 24rpx; box-shadow:0 8rpx 22rpx rgba(120,90,50,0.08); }

/* status panel */
.bars { display:grid; grid-template-columns:1fr 1fr; gap:14rpx 26rpx; }
.bar { display:flex; align-items:center; gap:12rpx; }
.bar-lab { width:64rpx; font-size:23rpx; color:var(--soft); flex-shrink:0; }
.bar-track { flex:1; height:14rpx; background:var(--line); border-radius:999rpx; overflow:hidden; }
.bar-fill { height:100%; border-radius:999rpx; transition:width 0.4s ease; }
.status-foot { display:flex; align-items:center; justify-content:space-between; margin-top:18rpx; }
.grow { font-size:22rpx; color:var(--soft); }
.bondlab { font-size:22rpx; color:var(--accent); }

/* primary action */
.primary { display:flex; align-items:center; justify-content:center; gap:14rpx; height:104rpx; border-radius:26rpx; background:var(--card); border:2rpx solid var(--line); box-shadow:0 8rpx 20rpx rgba(120,90,50,0.08); }
.primary--need { background:var(--accent); border-color:var(--accent); box-shadow:0 8rpx 22rpx rgba(224,122,82,0.34); animation:nudge 1.8s ease-in-out infinite; }
.primary:active { transform:translateY(3rpx); }
.p-emoji { font-size:44rpx; }
.p-label { font-size:34rpx; font-weight:800; color:var(--ink); }
.primary--need .p-label { color:#fff; }
.p-reward { font-size:23rpx; font-weight:700; color:var(--accent); background:rgba(255,255,255,0.92); border-radius:10rpx; padding:3rpx 12rpx; }
.primary--need .p-reward { color:var(--accent); }
@keyframes nudge { 0%,92%,100%{transform:scale(1);} 96%{transform:scale(1.025);} }

/* action grid */
.acts { display:flex; flex-direction:column; gap:10rpx; }
.acts-lab { font-size:22rpx; color:var(--ink); font-weight:700; margin-top:6rpx; }
.acts-sub { font-weight:400; color:var(--soft); font-size:20rpx; margin-left:6rpx; }
.act-row { display:flex; gap:14rpx; }
.act { flex:1; position:relative; display:flex; flex-direction:column; align-items:center; gap:4rpx; background:var(--accent-soft); border-radius:18rpx; padding:16rpx 0 14rpx; }
.act--fun { background:var(--line); }
.act:active { transform:translateY(2rpx); filter:brightness(0.97); }
.act--off { opacity:0.42; }
.a-emoji { font-size:42rpx; }
.a-label { font-size:23rpx; color:var(--ink); }
.a-reward { font-size:18rpx; font-weight:700; color:var(--accent); }
.a-done { font-size:18rpx; color:var(--soft); }

/* bottom nav */
.nav { display:flex; justify-content:space-around; padding:6rpx 0 0; }
.nav-item { display:flex; flex-direction:column; align-items:center; gap:4rpx; padding:8rpx 18rpx; }
.nav-item:active { opacity:0.6; }
.n-emoji { font-size:34rpx; }
.n-lab { font-size:20rpx; color:var(--soft); }

/* ===== idle / reaction animations ===== */
@keyframes bob { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12rpx);} }
@keyframes jiggle { 0%,100%{transform:scale(1,1);} 50%{transform:scale(1.06,0.94);} }
@keyframes flt { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-14rpx) rotate(-3deg);} }
@keyframes pop { 0%,100%{transform:scale(1);} 45%{transform:scale(1.09);} 55%{transform:scale(0.96);} }
@keyframes bounce { 0%{transform:scale(1) translateY(0);} 30%{transform:scale(1.16) translateY(-24rpx);} 60%{transform:scale(0.92);} 100%{transform:scale(1);} }
.anim-bob{animation:bob 2.6s ease-in-out infinite;} .anim-jiggle{animation:jiggle 2.2s ease-in-out infinite;}
.anim-float{animation:flt 3.4s ease-in-out infinite;} .anim-pop{animation:pop 2s ease-in-out infinite;}
.anim-bounce{animation:bounce 0.5s ease-out;}
@keyframes squish { 0%,100%{transform:scale(1,1);} 35%{transform:scale(1.2,0.82);} 65%{transform:scale(0.9,1.12);} 82%{transform:scale(1.04,0.97);} }
@keyframes hop { 0%,100%{transform:translateY(0) scale(1);} 28%{transform:translateY(-34rpx) scale(1.06,0.96);} 52%{transform:translateY(0) scale(0.94,1.08);} 74%{transform:translateY(-14rpx);} }
@keyframes eat { 0%,100%{transform:scale(1);} 22%{transform:scale(1.08,0.92) translateY(4rpx);} 48%{transform:scale(0.95,1.06);} 72%{transform:scale(1.03,0.98);} }
.anim-squish{animation:squish 0.55s ease;} .anim-hop{animation:hop 0.62s ease;} .anim-eat{animation:eat 0.5s ease;}

/* ===== modals ===== */
.mask { position:fixed; inset:0; background:rgba(40,30,20,0.45); display:flex; align-items:center; justify-content:center; z-index:50; }
.modal { width:600rpx; background:var(--card,#FFFDF7); border-radius:28rpx; padding:32rpx; }
.modal-title { font-size:32rpx; font-weight:800; color:var(--ink,#5A4E42); margin-bottom:20rpx; }
.road-big { font-size:28rpx; color:var(--ink,#5A4E42); background:var(--accent-soft,#FBF4E8); border-radius:14rpx; padding:16rpx 18rpx; }
.srow { display:flex; align-items:center; margin-bottom:14rpx; }
.slabel { width:72rpx; font-size:24rpx; color:var(--soft,#8A7D6E); }
.sbar { flex:1; height:16rpx; background:var(--line,#F1E8D8); border-radius:999rpx; overflow:hidden; margin:0 16rpx; }
.sfill { height:100%; border-radius:999rpx; }
.sval { width:54rpx; text-align:right; font-size:24rpx; color:var(--soft,#A89B8C); }
.srow2 { font-size:24rpx; color:var(--ink,#6A5E50); margin-top:12rpx; line-height:1.5; }
.plabel { font-size:24rpx; color:var(--soft,#8A7D6E); margin:20rpx 0 12rpx; }
.themes { display:flex; gap:20rpx; }
.swatch { display:flex; flex-direction:column; align-items:center; padding:8rpx; border:4rpx solid transparent; border-radius:18rpx; }
.swatch.sel { border-color:var(--accent,#E8845B); }
.swatch-chip { width:96rpx; height:72rpx; border-radius:16rpx; background:linear-gradient(180deg,var(--scene1),var(--scene2)); border:3rpx solid var(--line); }
.swatch-name { font-size:22rpx; color:var(--ink,#6A5E50); margin-top:8rpx; }
.namerow { display:flex; align-items:center; gap:16rpx; }
.ninput { flex:1; background:var(--bg,#FBF4E8); border-radius:14rpx; padding:16rpx 20rpx; font-size:28rpx; }
.solid-btn { margin-top:8rpx; background:var(--accent,#E8845B); color:#fff; border-radius:999rpx; padding:18rpx 56rpx; font-size:28rpx; text-align:center; }
.solid-btn.small { margin-top:0; padding:16rpx 30rpx; font-size:26rpx; }
.ghost-btn { margin-top:26rpx; text-align:center; background:var(--line,#EFE6D8); color:var(--ink,#6A5E50); border-radius:999rpx; padding:18rpx; font-size:26rpx; }

/* recap */
.recap { display:flex; flex-direction:column; align-items:center; }
.recap-title { font-size:34rpx; font-weight:800; color:var(--accent,#E8845B); }
.recap-sprite { width:220rpx; height:220rpx; image-rendering:pixelated; margin:8rpx 0; }
.recap-line { font-size:27rpx; color:var(--ink,#5A4E42); text-align:center; line-height:1.5; }
.recap-meta { font-size:23rpx; color:var(--soft,#A89B8C); margin-top:10rpx; }
