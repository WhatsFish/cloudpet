/* pixel font everywhere (loaded global in app.ts; falls back gracefully) */
page { font-family: "Zpix", "PingFang SC", -apple-system, "Microsoft YaHei", sans-serif; }

/* ===== theme palettes (device skins) ===== */
.theme-cream { --bg:#FBF1DC; --shell:#F1D29A; --rim:#CF9E5E; --hi:#FCEFCB; --accent:#E8845B; --btn:#EBA06A; --lcd:#D6E2A6; --lcd2:#C3D08A; --lcd-ink:#5A6B36; --shell-ink:#9A7340; }
.theme-mint  { --bg:#EAF6F0; --shell:#A9DAC9; --rim:#6FAFA0; --hi:#CFEFE2; --accent:#F0875E; --btn:#7FC7B6; --lcd:#CBDBA0; --lcd2:#B6C988; --lcd-ink:#3F6150; --shell-ink:#3C6256; }
.theme-dusk  { --bg:#F0ECF7; --shell:#C7B4E2; --rim:#9A80C4; --hi:#E0D5F0; --accent:#F2A65A; --btn:#B49AD8; --lcd:#D2D6B8; --lcd2:#BFC4A0; --lcd-ink:#5A5740; --shell-ink:#6E5A92; }

.screen { min-height:100vh; background:var(--bg); display:flex; flex-direction:column; align-items:center; padding:24rpx 0 60rpx; box-sizing:border-box; }
.center-screen { justify-content:center; }
.muted { color:#A89B8C; }
.retry { margin-top:28rpx; background:var(--accent); color:#fff; border-radius:999rpx; padding:18rpx 56rpx; }

/* ===== device shell ===== */
.device {
  width:702rpx; box-sizing:border-box;
  background:var(--shell); border:8rpx solid var(--rim); border-radius:60rpx;
  padding:22rpx 28rpx 30rpx;
  box-shadow:0 14rpx 40rpx rgba(120,90,50,0.22), inset 0 6rpx 0 var(--hi);
}
.brand { text-align:center; color:var(--accent); font-weight:700; letter-spacing:4rpx; font-size:28rpx; margin:4rpx 0 16rpx; }

/* ===== LCD ===== */
.lcd { position:relative; background:var(--lcd); border:6rpx solid var(--rim); border-radius:24rpx; padding:14rpx 16rpx; overflow:hidden; box-shadow:inset 0 0 24rpx rgba(60,70,40,0.18); }
.bg { position:absolute; left:0; top:0; right:0; bottom:0; width:100%; height:100%; image-rendering:pixelated; opacity:0.5; z-index:0; }
.lcd-grid {
  position:absolute; left:0; top:0; right:0; bottom:0; pointer-events:none; opacity:0.45; z-index:1;
  background-image:
    repeating-linear-gradient(0deg, rgba(40,50,30,0.10) 0, rgba(40,50,30,0.10) 1rpx, transparent 1rpx, transparent 6rpx),
    repeating-linear-gradient(90deg, rgba(40,50,30,0.06) 0, rgba(40,50,30,0.06) 1rpx, transparent 1rpx, transparent 10rpx);
}

/* V2 §4 濒危 暗角: a dark radial vignette over the LCD signals 虚弱/濒危 at a glance (派生占位 —
   no new art; the weak sprite + slump animation + this overlay convey it). Sits above bg/grid,
   below the pet (z-index 2) so the creature stays visible at the dim center. */
.vignette { position:absolute; left:0; top:0; right:0; bottom:0; z-index:1; pointer-events:none;
  background:radial-gradient(ellipse at 50% 58%, transparent 28%, rgba(20,16,30,0.30) 72%, rgba(15,10,24,0.52) 100%);
  animation:vigpulse 3.2s ease-in-out infinite; }
@keyframes vigpulse { 0%,100%{opacity:0.78;} 50%{opacity:1;} }
.road { position:relative; z-index:2; display:flex; align-items:center; gap:10rpx; margin-bottom:4rpx; }
.lvchip { font-size:22rpx; font-weight:700; color:#fff; background:var(--accent); border-radius:8rpx; padding:2rpx 10rpx; }
.lvbar { width:120rpx; height:10rpx; background:rgba(60,70,40,0.22); border-radius:999rpx; overflow:hidden; }
.lvfill { height:100%; background:var(--accent); border-radius:999rpx; transition:width 0.4s ease; }
.roadtxt { flex:1; font-size:21rpx; color:var(--lcd-ink); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

/* V2 screen-fit: taller fixed stage viewport so the bounded sprite (≤~1.10× of 208rpx ≈ 229rpx) plus
   the tallest hat/光环 overlay and top FX always sit INSIDE the frame, feet planted (align flex-end).
   Body size is now stage-driven & capped backend-side (displaySizeScale), so this never overflows. */
.stage-wrap { position:relative; z-index:2; display:flex; justify-content:center; align-items:flex-end; height:252rpx; }
.sprite { width:208rpx; height:208rpx; image-rendering:pixelated; -ms-interpolation-mode:nearest-neighbor; }
/* particle burst (multiple flying emojis per action) */
.particle { position:absolute; top:70rpx; font-size:40rpx; animation:floatburst 1s ease-out forwards; }
@keyframes floatburst { 0%{transform:translateY(24rpx) scale(0.4) rotate(0);opacity:0;} 22%{opacity:1;} 100%{transform:translateY(-130rpx) scale(1.15) rotate(var(--rot,0));opacity:0;} }
.floattag { position:absolute; top:24rpx; right:20rpx; z-index:3; font-size:26rpx; font-weight:700; color:var(--accent); background:rgba(255,255,255,0.78); border-radius:10rpx; padding:2rpx 12rpx; animation:floatup 1s ease-out forwards; }
@keyframes floatup { 0%{transform:translateY(0) scale(0.5);opacity:0;} 25%{opacity:1;transform:translateY(-12rpx) scale(1);} 100%{transform:translateY(-72rpx) scale(1);opacity:0;} }
.zzz { position:absolute; top:36rpx; right:40rpx; font-size:30rpx; color:#8FA0C8; letter-spacing:4rpx; animation:zzzfloat 2.4s ease-in-out infinite; }
@keyframes zzzfloat { 0%,100%{transform:translateY(0);opacity:0.5;} 50%{transform:translateY(-8rpx);opacity:1;} }

/* bond hearts + growth */
.metarow { position:relative; z-index:2; display:flex; align-items:center; justify-content:space-between; margin-top:4rpx; }
.hearts { display:flex; flex-direction:column; align-items:flex-start; gap:3rpx; }
.hearts-row { display:flex; align-items:center; gap:2rpx; }
.heart { font-size:26rpx; color:rgba(90,70,50,0.28); }
.heart.on { color:#E8607A; }
.bondlab { font-size:18rpx; color:var(--lcd-ink); margin-left:8rpx; opacity:0.8; }
/* thin progress to the NEXT heart so bond visibly moves within a session (hearts only tick at a boundary). */
.bondnext { width:108rpx; height:5rpx; border-radius:3rpx; background:rgba(232,96,122,0.18); overflow:hidden; }
.bondnext-fill { height:100%; border-radius:3rpx; background:#E8607A; transition:width 0.4s ease; }
.growth { font-size:20rpx; color:var(--lcd-ink); opacity:0.85; }

/* the pet's voice / need card */
.needcard { position:relative; z-index:2; margin-top:6rpx; background:rgba(255,255,255,0.62); border:2rpx solid var(--lcd2); border-radius:16rpx; padding:14rpx 18rpx; font-size:26rpx; line-height:1.45; color:var(--lcd-ink); min-height:36rpx; }

/* idle "alive" tweens */
@keyframes bob { 0%,100%{transform:translateY(0);} 50%{transform:translateY(-12rpx);} }
@keyframes jiggle { 0%,100%{transform:scale(1,1);} 50%{transform:scale(1.06,0.94);} }
@keyframes flt { 0%,100%{transform:translateY(0) rotate(0);} 50%{transform:translateY(-14rpx) rotate(-3deg);} }
@keyframes pop { 0%,100%{transform:scale(1);} 45%{transform:scale(1.09);} 55%{transform:scale(0.96);} }
@keyframes bounce { 0%{transform:scale(1) translateY(0);} 30%{transform:scale(1.16) translateY(-24rpx);} 60%{transform:scale(0.92);} 100%{transform:scale(1);} }
.anim-bob{animation:bob 2.6s ease-in-out infinite;} .anim-jiggle{animation:jiggle 2.2s ease-in-out infinite;}
.anim-float{animation:flt 3.4s ease-in-out infinite;} .anim-pop{animation:pop 2s ease-in-out infinite;}
.anim-bounce{animation:bounce 0.5s ease-out;}
/* per-action reactions (richer feedback for 摸摸 / 陪玩 / 喂食) */
@keyframes squish { 0%,100%{transform:scale(1,1);} 35%{transform:scale(1.2,0.82);} 65%{transform:scale(0.9,1.12);} 82%{transform:scale(1.04,0.97);} }
@keyframes hop { 0%,100%{transform:translateY(0) scale(1);} 28%{transform:translateY(-34rpx) scale(1.06,0.96);} 52%{transform:translateY(0) scale(0.94,1.08);} 74%{transform:translateY(-14rpx);} }
@keyframes eat { 0%,100%{transform:scale(1);} 22%{transform:scale(1.08,0.92) translateY(4rpx);} 48%{transform:scale(0.95,1.06);} 72%{transform:scale(1.03,0.98);} }
.anim-squish{animation:squish 0.55s ease;} .anim-hop{animation:hop 0.62s ease;} .anim-eat{animation:eat 0.5s ease;}
/* bad-state idle motion — matches the sad/sick sprite frame so distress reads at a glance */
@keyframes sickshiver { 0%,100%{transform:translateX(0) rotate(0);} 20%{transform:translateX(-4rpx) rotate(-1.5deg);} 40%{transform:translateX(4rpx) rotate(1.5deg);} 60%{transform:translateX(-3rpx) rotate(-1deg);} 80%{transform:translateX(3rpx) rotate(1deg);} }
@keyframes weakslump { 0%,100%{transform:translateY(0) scale(1,1);} 50%{transform:translateY(9rpx) scale(1.03,0.95);} }
@keyframes itchwobble { 0%,78%,100%{transform:rotate(0);} 83%{transform:rotate(-5deg) translateX(-3rpx);} 88%{transform:rotate(5deg) translateX(3rpx);} 93%{transform:rotate(-3deg);} 97%{transform:rotate(2deg);} }
.anim-sick{animation:sickshiver 0.42s ease-in-out infinite;}
.anim-weak{animation:weakslump 2.8s ease-in-out infinite;}
.anim-itch{animation:itchwobble 2.6s ease-in-out infinite;}
/* small looping ambient mark for a bad state (💢 sick / 💫 hungry / 🪰 dirty) */
.statusfx { position:absolute; top:28rpx; left:46rpx; z-index:3; font-size:32rpx; animation:statusbob 1.5s ease-in-out infinite; }
@keyframes statusbob { 0%,100%{transform:translateY(0) scale(0.9) rotate(-6deg);opacity:0.5;} 50%{transform:translateY(-12rpx) scale(1.06) rotate(6deg);opacity:1;} }

/* tapping the creature itself (or the need card) = 摸摸 */
.stage-wrap { transition:transform 0.12s ease; }
.stage-wrap:active { transform:scale(0.97); }
.needcard:active { background:rgba(255,255,255,0.82); }
/* day-1 / all-done come-back hook — a calm persistent banner under the need card. */
.comeback { position:relative; z-index:2; margin-top:6rpx; background:rgba(120,150,200,0.14); border:2rpx solid rgba(120,150,200,0.32); border-radius:14rpx; padding:10rpx 16rpx; font-size:22rpx; line-height:1.4; color:#5C6B86; }
/* 体型: the sprite grows from its feet as weight rises (scale wrapper, keeps idle anim intact) */
.sprite-scale { position:relative; display:flex; justify-content:center; align-items:flex-end; transform-origin:center bottom; transition:transform 0.6s ease; }
/* 可装饰 head overlay: same 208rpx box as the sprite, bottom-aligned; per-render translateY (inline
   style) lifts the hat's contact row onto the creature/stage head-top. Scales with .sprite-scale. */
.deco-hat { position:absolute; left:50%; bottom:0; width:208rpx; height:208rpx; margin-left:-104rpx; image-rendering:pixelated; -ms-interpolation-mode:nearest-neighbor; pointer-events:none; z-index:3; }
/* V2 §5 光环: full-sprite overlay BEHIND the creature (z below the sprite). Same 208rpx box, centered,
   scales with .sprite-scale. Soft additive-ish glow via a gentle pulse. Dimmed while 濒危. */
.deco-aura { position:absolute; left:50%; bottom:0; width:208rpx; height:208rpx; margin-left:-104rpx; image-rendering:pixelated; -ms-interpolation-mode:nearest-neighbor; pointer-events:none; z-index:-1; opacity:0.9; animation:aurapulse 3s ease-in-out infinite; }
.deco-aura.is-dim { opacity:0.25; }
@keyframes aurapulse { 0%,100%{opacity:0.72; transform:scale(1);} 50%{opacity:1; transform:scale(1.05);} }

/* ===== 灵感火花 spark bar (tap for EXP; regen countdown when empty) ===== */
.sparkbar { display:flex; align-items:center; justify-content:center; gap:12rpx; margin-top:14rpx; height:66rpx; border-radius:18rpx; background:var(--hi); border:2rpx solid var(--rim); }
.sparkbar--on { background:#fff; border:3rpx solid #F2C53D; box-shadow:0 0 0 4rpx rgba(242,197,61,0.18); }
.sparkbar:active { transform:translateY(2rpx); }
.spark-emoji { font-size:30rpx; }
.spark-text { font-size:25rpx; color:var(--shell-ink); font-weight:700; }
.sparkbar--on .spark-text { color:#A9791C; }
.spark-n { font-size:23rpx; font-weight:800; color:#fff; background:#F2C53D; border-radius:999rpx; padding:1rpx 12rpx; }

/* ===== more drawer ===== */
.handle { text-align:center; font-size:23rpx; color:var(--shell-ink); margin:16rpx 0 0; padding:8rpx; opacity:0.85; }
.drawer { max-height:0; overflow:hidden; transition:max-height 0.24s ease; }
.drawer.open { max-height:540rpx; }
.drow-lab { font-size:21rpx; color:var(--shell-ink); margin:12rpx 4rpx 6rpx; }
.dacts { display:flex; gap:14rpx; }
.dact { flex:1; display:flex; flex-direction:column; align-items:center; background:var(--hi); border-radius:16rpx; padding:12rpx 0; }
.dact:active { background:#fff; }
.dact--off { opacity:0.4; }
.de { font-size:38rpx; } .dl { font-size:21rpx; color:var(--shell-ink); margin-top:2rpx; }
.dsub { font-size:18rpx; opacity:0.7; color:var(--shell-ink); margin-top:1rpx; min-height:20rpx; }
.dact--due { background:#fff; box-shadow:inset 0 0 0 2rpx var(--accent); }
.dact--due .dsub { color:var(--accent); opacity:1; font-weight:700; }
/* nav/utility row — deliberately SECONDARY (small, muted, no filled tile) so it reads as
   "查看/设置" links, NOT another action button, to avoid mis-taps with the 照顾/陪伴 tiles above */
.dnav-lab { text-align:center; font-size:19rpx; color:var(--shell-ink); opacity:0.5; letter-spacing:3rpx; margin:18rpx 0 8rpx; }
.dnav { display:flex; gap:8rpx; }
.dnav-item { flex:1; display:flex; flex-direction:column; align-items:center; gap:3rpx; padding:8rpx 0; border-radius:12rpx; opacity:0.72; }
.dnav-item:active { background:rgba(255,255,255,0.5); opacity:1; }
.dnav-i { font-size:30rpx; }
.dnav-t { font-size:19rpx; color:var(--shell-ink); }

/* ===== A/B/C buttons — each a distinct job (A 照顾 · B 陪伴 · C 路线/进化) ===== */
.buttons { display:flex; justify-content:center; gap:22rpx; margin-top:22rpx; }
.abtn { position:relative; flex:1; max-width:200rpx; min-height:128rpx; border-radius:28rpx; background:var(--btn); border:4rpx solid var(--rim); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2rpx; box-shadow:0 6rpx 0 var(--rim), inset 0 4rpx 0 rgba(255,255,255,0.35); }
.abtn:active { transform:translateY(4rpx); box-shadow:0 2rpx 0 var(--rim); }
.abtn--need { background:#fff; border:4rpx solid var(--accent); box-shadow:0 0 0 4rpx rgba(232,132,91,0.16), 0 6rpx 0 var(--rim); }
.abtn--off { opacity:0.55; }
.abk { font-size:20rpx; font-weight:800; color:rgba(255,255,255,0.7); letter-spacing:1rpx; }
.abtn--need .abk { color:var(--accent); }
.abe { font-size:46rpx; line-height:1; }
.abl { font-size:21rpx; color:#fff; opacity:0.95; }
.abtn--need .abl { color:var(--shell-ink); font-weight:700; opacity:1; }
.abr { position:absolute; top:-12rpx; right:-6rpx; font-size:19rpx; font-weight:700; color:#fff; background:var(--accent); border-radius:999rpx; padding:2rpx 10rpx; box-shadow:0 2rpx 6rpx rgba(0,0,0,0.15); }

/* ===== modals ===== */
.mask { position:fixed; left:0; top:0; right:0; bottom:0; background:rgba(40,30,20,0.45); display:flex; align-items:center; justify-content:center; z-index:50; }
.panel { width:600rpx; background:#FFFDF7; border-radius:28rpx; padding:32rpx; }
.panel-title { font-size:32rpx; font-weight:700; color:#5A4E42; margin-bottom:20rpx; }
.road-big { font-size:28rpx; color:#5A4E42; background:#FBF4E8; border-radius:14rpx; padding:16rpx 18rpx; }
.srow { display:flex; align-items:center; margin-bottom:14rpx; }
.slabel { width:72rpx; font-size:24rpx; color:#8A7D6E; }
.sbar { flex:1; height:16rpx; background:#F1E8D8; border-radius:999rpx; overflow:hidden; margin:0 16rpx; }
.sfill { height:100%; border-radius:999rpx; }
.sval { width:54rpx; text-align:right; font-size:24rpx; color:#A89B8C; }
.srow2 { font-size:24rpx; color:#6A5E50; margin-top:12rpx; line-height:1.5; }
.plabel { font-size:24rpx; color:#8A7D6E; margin:20rpx 0 12rpx; }
.themes { display:flex; gap:20rpx; }
.swatch { display:flex; flex-direction:column; align-items:center; padding:8rpx; border:4rpx solid transparent; border-radius:18rpx; }
.swatch.sel { border-color:#E8845B; }
.swatch-shell { width:96rpx; height:120rpx; border-radius:18rpx; background:var(--shell); border:5rpx solid var(--rim); box-shadow:inset 0 0 0 12rpx var(--lcd); }
.swatch-name { font-size:22rpx; color:#6A5E50; margin-top:8rpx; }
.namerow { display:flex; align-items:center; gap:16rpx; }
.ninput { flex:1; background:#FBF4E8; border-radius:14rpx; padding:16rpx 20rpx; font-size:28rpx; }
.nbtn { background:#E8845B; color:#fff; border-radius:14rpx; padding:16rpx 30rpx; font-size:26rpx; }
.pbtn { margin-top:26rpx; text-align:center; background:#EFE6D8; color:#6A5E50; border-radius:999rpx; padding:18rpx; font-size:26rpx; }

/* ===== roadmap panel (info structure + tips + 灵感 explainer) ===== */
.panel--road { max-height:84vh; overflow-y:auto; }

/* 衣柜 / wardrobe */
.panel--ward { max-height:84vh; overflow-y:auto; }
.ward-scroll { max-height:64vh; }
.ward-cat { font-size:24rpx; font-weight:700; color:#9A7340; margin:14rpx 2rpx 8rpx; }
.ward-card--aura.ward-card--on { border-color:#D9A93A; background:#FBF3DE; }
.ward-sub { font-size:21rpx; color:#8A7D6E; margin:-8rpx 0 18rpx; line-height:1.5; }
.ward-loading { text-align:center; color:#8A7D6E; font-size:24rpx; padding:40rpx 0; }
.ward-grid { display:flex; flex-wrap:wrap; gap:14rpx; }
.ward-card { width:168rpx; box-sizing:border-box; background:#FBF6EC; border:3rpx solid #F0E7D6; border-radius:16rpx; padding:10rpx 6rpx 12rpx; display:flex; flex-direction:column; align-items:center; gap:2rpx; }
.ward-card--on { border-color:#E8607A; background:#FFF1F5; }
.ward-card--lock { opacity:0.62; }
.ward-img { width:120rpx; height:96rpx; image-rendering:pixelated; -ms-interpolation-mode:nearest-neighbor; }
.ward-card--lock .ward-img { filter:grayscale(0.9); }
.ward-name { font-size:23rpx; font-weight:700; color:#5A4E42; }
.ward-tag { font-size:20rpx; color:#C2557A; }
.ward-card--on .ward-tag { font-weight:700; }
.ward-lock { font-size:18rpx; color:#9A8E7E; text-align:center; line-height:1.35; }
.rm-head { display:flex; align-items:center; gap:18rpx; background:#FBF4E8; border-radius:16rpx; padding:14rpx 16rpx; margin-bottom:14rpx; }
.rm-sprite { width:118rpx; height:118rpx; image-rendering:pixelated; flex-shrink:0; }
.rm-head-r { flex:1; min-width:0; }
.rm-lv { font-size:26rpx; font-weight:700; color:#5A4E42; }
.rm-bar { height:14rpx; background:#EBDFC8; border-radius:999rpx; overflow:hidden; margin:8rpx 0; }
.rm-fill { height:100%; background:#E8845B; border-radius:999rpx; transition:width 0.4s ease; }
.rm-next { font-size:22rpx; color:#8A7D6E; line-height:1.45; }
.rm-speed { margin-top:5rpx; font-size:21rpx; color:#C2557A; background:#FFF1F5; border-radius:10rpx; padding:4rpx 10rpx; line-height:1.4; display:inline-block; }
.tip { display:flex; gap:12rpx; padding:12rpx 2rpx; border-top:2rpx solid #F1E8D8; }
.tip:first-of-type { border-top:none; }
.tip-ico { font-size:34rpx; line-height:1.2; flex-shrink:0; width:46rpx; text-align:center; }
.tip-r { flex:1; min-width:0; }
.tip-h { font-size:25rpx; font-weight:700; color:#5A4E42; margin-bottom:4rpx; }
.tip-b { font-size:22rpx; color:#7A6E60; line-height:1.55; }
.tip--spark { background:#FFFBEF; border:2rpx solid #F2E2B0; border-radius:14rpx; padding:12rpx; border-top:none; margin-top:8rpx; }
.tip--spark .tip-b { color:#A9791C; }
.rm-foot { font-size:21rpx; color:#8A7D6E; text-align:center; margin-top:16rpx; line-height:1.5; }

/* ===== recap overlay ===== */
.recap { width:560rpx; background:#FFFDF7; border-radius:28rpx; padding:32rpx; display:flex; flex-direction:column; align-items:center; }
.recap-title { font-size:34rpx; font-weight:800; color:var(--accent,#E8845B); }
.recap-sprite { width:200rpx; height:200rpx; image-rendering:pixelated; margin:8rpx 0; }
.recap-line { font-size:27rpx; color:#5A4E42; text-align:center; line-height:1.5; }
.recap-meta { font-size:23rpx; color:#A89B8C; margin-top:10rpx; }
.recap-btn { margin-top:24rpx; background:#E8845B; color:#fff; border-radius:999rpx; padding:18rpx 56rpx; font-size:28rpx; }

/* ===== teen fork chooser ===== */
.forkpanel { width:640rpx; background:#FFFDF7; border-radius:28rpx; padding:30rpx 26rpx; }
.fork-title { font-size:34rpx; font-weight:800; color:var(--accent,#E8845B); text-align:center; }
.fork-sub { font-size:23rpx; color:#8A7D6E; text-align:center; margin:8rpx 0 20rpx; line-height:1.5; }
.fork-grid { display:flex; flex-wrap:wrap; gap:18rpx; justify-content:center; }
.fork-card { width:280rpx; box-sizing:border-box; background:#FBF4E8; border:3rpx solid transparent; border-radius:20rpx; padding:14rpx 12rpx 16rpx; display:flex; flex-direction:column; align-items:center; }
.fork-card:active { background:#fff; transform:translateY(2rpx); }
.fork-card--rec { border-color:var(--accent,#E8845B); box-shadow:0 0 0 3rpx rgba(232,132,91,0.14); }
.fork-img { width:148rpx; height:148rpx; image-rendering:pixelated; }
.fork-name { font-size:26rpx; font-weight:700; color:#5A4E42; margin-top:6rpx; display:flex; align-items:center; gap:8rpx; }
.fork-rec { font-size:18rpx; font-weight:700; color:#fff; background:var(--accent,#E8845B); border-radius:999rpx; padding:1rpx 10rpx; }
.fork-blurb { font-size:21rpx; color:#8A7D6E; text-align:center; line-height:1.4; margin-top:4rpx; }
.fork-cancel { margin-top:22rpx; text-align:center; background:#EFE6D8; color:#6A5E50; border-radius:999rpx; padding:16rpx; font-size:25rpx; }
.fork-open { margin-top:16rpx; text-align:center; background:var(--accent,#E8845B); color:#fff; border-radius:999rpx; padding:18rpx; font-size:26rpx; font-weight:700; }
