.q-progress { text-align: center; color: #A89B8C; font-size: 26rpx; margin: 24rpx 0 16rpx; }
.q-dots { display: flex; justify-content: center; gap: 12rpx; margin-bottom: 56rpx; }
.dot { width: 16rpx; height: 16rpx; border-radius: 999rpx; background: #EDE0CC; }
.dot--on { background: #E8845B; }

.q-prompt {
  font-size: 40rpx; font-weight: 700; line-height: 1.5;
  text-align: center; padding: 0 16rpx; margin-bottom: 56rpx; color: #4A3F35;
}

.q-options { display: flex; flex-direction: column; gap: 22rpx; }
.q-opt {
  background: #FFFFFF; border-radius: 24rpx; padding: 32rpx 30rpx;
  font-size: 30rpx; color: #5A4E42; line-height: 1.5;
  box-shadow: 0 6rpx 20rpx rgba(180,150,110,0.10);
}
.q-opt:active { background: #FFF3E6; transform: scale(0.99); }

.q-back { text-align: center; color: #B0A28E; font-size: 26rpx; margin-top: 48rpx; }
