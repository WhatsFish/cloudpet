<view class="page" wx:if="{{!loading && !noPet}}">
  <view class="card me-head">
    <image class="me-sprite pixel" src="{{sprite}}" mode="aspectFit" />
    <view class="me-info">
      <view wx:if="{{!editing}}" class="me-name-row">
        <text class="me-name">{{name}}</text>
        <text class="me-edit" bindtap="startEdit">改名</text>
      </view>
      <view wx:else class="me-edit-row">
        <input class="me-input" value="{{nameInput}}" maxlength="12" bindinput="onNameInput" />
        <text class="me-save" bindtap="saveName">保存</text>
      </view>
      <view class="chip">{{stageLabel}}</view>
    </view>
  </view>

  <view class="card stats-card">
    <view class="stat-line"><text class="muted">认识天数</text><text>{{daysKnown}} 天</text></view>
    <view class="stat-line"><text class="muted">连续陪伴</text><text>{{streakDays}} 天</text></view>
    <view class="stat-line"><text class="muted">亲密度</text><text>{{bond}} / 1000</text></view>
  </view>

  <view class="card">
    <view class="label">小仓库</view>
    <view class="items">
      <text wx:for="{{items}}" wx:key="label" class="item-chip">{{item.label}} {{item.qty}}</text>
    </view>
  </view>

  <view class="card about">
    <view class="label">关于</view>
    <view class="about-text">这是一只陪你慢慢长大的本命小宠。它会饿、会闹脾气、会想你，但<text class="hl">永远不会死，也不会走丢</text>。一人一只，慢慢养就好。</view>
  </view>
</view>

<view class="empty" wx:elif="{{noPet}}">
  <view>你还没有自己的本命宠</view>
  <view class="btn" style="margin-top:32rpx;display:inline-block;padding:18rpx 56rpx" bindtap="goQuiz">去测一测</view>
</view>

<view class="empty" wx:else>加载中…</view>
