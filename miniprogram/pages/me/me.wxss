.me-head { display: flex; align-items: center; }
.me-sprite { width: 140rpx; height: 140rpx; margin-right: 24rpx; }
.me-info { flex: 1; }
.me-name-row { display: flex; align-items: baseline; margin-bottom: 12rpx; }
.me-name { font-size: 40rpx; font-weight: 700; margin-right: 16rpx; }
.me-edit { font-size: 24rpx; color: #E8845B; }
.me-edit-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.me-input { background: #FBF4E8; border-radius: 14rpx; padding: 12rpx 18rpx; font-size: 30rpx; flex: 1; }
.me-save { font-size: 26rpx; color: #E8845B; margin-left: 18rpx; }

.stats-card .stat-line {
  display: flex; justify-content: space-between; padding: 16rpx 0;
  border-bottom: 2rpx solid #F4ECDD; font-size: 28rpx;
}
.stats-card .stat-line:last-child { border-bottom: none; }

.items { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.item-chip { background: #FFF0E0; color: #C9763F; border-radius: 999rpx; padding: 8rpx 22rpx; font-size: 24rpx; }

.about-text { font-size: 26rpx; line-height: 1.8; color: #6A5E50; margin-top: 8rpx; }
.hl { color: #E8845B; font-weight: 600; }
