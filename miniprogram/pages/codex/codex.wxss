page { font-family: "Zpix", "PingFang SC", -apple-system, "Microsoft YaHei", sans-serif; }
.codex-intro { font-size: 24rpx; line-height: 1.6; margin-bottom: 24rpx; color: #8A7D6E; }

.linecard {
  background: #FFFFFF; border-radius: 24rpx; padding: 20rpx 18rpx 22rpx;
  margin-bottom: 22rpx; box-shadow: 0 4rpx 14rpx rgba(180,150,110,0.08);
}
.linecard--bonded { background: #FFF3E0; box-shadow: 0 6rpx 20rpx rgba(232,132,91,0.22); }
.line-head { display: flex; align-items: center; gap: 12rpx; margin-bottom: 14rpx; }
.line-name { font-size: 30rpx; font-weight: 700; color: #5A4E42; }
.line-tag { background: #E8845B; color: #FFF; font-size: 18rpx; border-radius: 999rpx; padding: 2rpx 14rpx; }

.forms { display: flex; gap: 12rpx; }
.form {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  background: #FBF6EE; border-radius: 16rpx; padding: 12rpx 0 10rpx;
}
.form--true { background: #FFF0DC; border: 2rpx solid #EBC79A; }
.form-sprite { width: 96rpx; height: 96rpx; image-rendering: pixelated; -ms-interpolation-mode: nearest-neighbor; }
.form-label { font-size: 22rpx; color: #5A4E42; margin-top: 6rpx; }
.form-lean { font-size: 18rpx; color: #A89B8C; margin-top: 2rpx; }
